<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rem's Corner | Interstellar v18</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/skinview3d@3.0.0/dist/skinview3d.bundle.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <style>
        :root { --red: #dc2626; --orange: #f97316; --mc-gray: #313335; }
        body { background: radial-gradient(circle at top left, #450a0a 0%, #09090b 100%); color: #fff; font-family: 'Plus Jakarta Sans', sans-serif; height: 100vh; overflow: hidden; margin: 0; }
        
        /* SCRAMJET BROWSER UI */
        .browser-top { background: #202124; height: 45px; display: flex; align-items: center; padding: 0 15px; gap: 10px; border-bottom: 1px solid #3c4043; }
        .url-bar { flex: 1; background: #303134; border-radius: 20px; height: 28px; padding: 0 15px; border: none; color: #fff; font-size: 12px; outline: none; }
        .browser-frame { width: 100%; height: 500px; background: white; border-radius: 0 0 12px 12px; }

        /* MC LAUNCHER 1:1 */
        .mc-container { background: var(--mc-gray); width: 100%; height: 560px; border-radius: 4px; display: flex; flex-direction: column; border: 1px solid #111; overflow: hidden; }
        .mc-top-nav { background: #2b2b2b; height: 40px; display: flex; align-items: center; padding: 0 15px; gap: 20px; border-bottom: 1px solid #1a1a1a; }
        .mc-tab { font-size: 11px; color: #aaa; cursor: pointer; font-weight: 700; text-transform: uppercase; }
        .mc-tab.active { color: #fff; border-bottom: 2px solid #fff; padding-bottom: 11px; margin-bottom: -13px; }
        
        /* CALC & HISTORY */
        .widget { background: rgba(15, 15, 20, 0.98); padding: 2rem; border-radius: 50px; border: 1px solid rgba(220, 38, 38, 0.3); }
        .screen { background: #000; border-radius: 25px; padding: 1rem; text-align: right; font-family: 'JetBrains Mono'; color: var(--orange); font-size: 2.2rem; border: 1px solid var(--red); margin-bottom: 1rem; }
        .history-panel { height: 100px; background: #000; border-radius: 15px; margin-top: 10px; padding: 10px; font-size: 10px; font-family: 'JetBrains Mono'; color: #444; overflow-y: auto; }
        .key { height: 48px; border-radius: 24px; background: rgba(255,255,255,0.03); font-weight: 800; cursor: pointer; color: #fecaca; }
        .key:hover { background: var(--red); color: white; }

        #rem-os { position: fixed; inset: 0; background: #0a0a0c; z-index: 5000; display: none; flex-direction: column; border-top: 4px solid var(--red); }
    </style>
</head>
<body>

    <nav class="p-6 px-12 flex justify-between items-center border-b border-red-900/30">
        <div class="font-black text-2xl tracking-tighter text-white">REMS<span class="text-orange-500">CORNER</span></div>
        <button onclick="downloadSelf()" class="bg-red-600 text-white px-6 py-2 rounded-full font-bold text-[10px]">SAVE BUILD v18</button>
    </nav>

    <div class="grid grid-cols-[1fr_380px] gap-8 p-12 h-[calc(100vh-100px)]">
        <div class="bg-red-950/10 border border-red-500/20 p-10 rounded-[50px] backdrop-blur-md">
            <h1 class="text-5xl font-black mb-4 italic text-white uppercase tracking-tighter uppercase">Interstellar <span class="text-orange-500">Node</span></h1>
            <p class="text-red-100/60 leading-relaxed text-lg mb-4">DuckDuckGo Scramjet Proxy Online. MinecraftTS and Brotato Core synchronized.</p>
            <div class="flex gap-2">
                <span class="bg-green-600/20 text-green-400 text-[10px] px-3 py-1 rounded-full border border-green-500/30 font-bold tracking-widest">ENCRYPTED</span>
                <span class="bg-blue-600/20 text-blue-400 text-[10px] px-3 py-1 rounded-full border border-blue-500/30 font-bold tracking-widest">SCRAMJET_v2</span>
            </div>
        </div>

        <div class="widget">
            <div class="screen" id="calc-val">0</div>
            <div class="grid grid-cols-4 gap-2">
                <button id="btn-2nd" class="key" onclick="toggle2nd()">2nd</button>
                <button class="key" onclick="deleteChar()">DEL</button>
                <button class="key" onclick="handleClear()">AC</button>
                <button class="key text-orange-500" onclick="handleTuff()">÷</button>
                <button class="key" onclick="append('7')">7</button>
                <button class="key" onclick="append('8')">8</button>
                <button class="key" onclick="append('9')">9</button>
                <button class="key text-orange-500" onclick="append('*')">×</button>
                <button class="key" onclick="append('4')">4</button>
                <button class="key" onclick="append('5')">5</button>
                <button class="key" onclick="append('6')">6</button>
                <button class="key text-orange-500" onclick="append('-')">-</button>
                <button class="key" onclick="append('1')">1</button>
                <button class="key" onclick="append('2')">2</button>
                <button class="key" onclick="append('3')">3</button>
                <button class="key text-orange-500" onclick="append('+')">+</button>
                <button class="key col-span-2" onclick="append('0')">0</button>
                <button class="key" onclick="append('.')">.</button>
                <button class="key bg-gradient-to-br from-red-600 to-orange-600 text-white border-none" onclick="handleEnter()">=</button>
            </div>
            <div class="history-panel" id="history">LOGS: [EMPTY]</div>
        </div>
    </div>

    <div id="rem-os">
        <div class="flex flex-1">
            <div class="w-64 bg-black p-8 border-r border-red-900/30 flex flex-col gap-2">
                <button onclick="showTab('mc')" class="text-left p-4 rounded-xl hover:bg-red-900/20 font-bold transition">🎮 Minecraft</button>
                <button onclick="showTab('bt')" class="text-left p-4 rounded-xl hover:bg-orange-900/20 font-bold transition text-orange-500">🥔 Brotato</button>
                <button onclick="showTab('scram')" class="text-left p-4 rounded-xl hover:bg-blue-900/20 font-bold transition text-blue-400">🌐 Scramjet Browser</button>
                <button onclick="showTab('repo')" class="text-left p-4 rounded-xl hover:bg-zinc-800 font-bold transition text-zinc-400">📂 Repo Source</button>
                <button onclick="closeOS()" class="mt-auto text-red-500 font-black text-[10px] text-center p-4 hover:text-white transition">[EXIT]</button>
            </div>

            <div class="flex-1 p-10 bg-[#0c0c0e] overflow-y-auto">
                
                <div id="tab-scram" class="os-tab">
                    <div class="browser-top">
                        <div class="flex gap-2 mr-4">
                            <div class="w-3 h-3 rounded-full bg-red-500"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                            <div class="w-3 h-3 rounded-full bg-green-500"></div>
                        </div>
                        <input type="text" class="url-bar" id="browser-input" placeholder="Search DuckDuckGo or enter URL..." onkeydown="if(event.key==='Enter') navigateBrowser()">
                        <button onclick="navigateBrowser()" class="bg-blue-600 px-4 py-1 rounded-full text-[10px] font-bold">GOTO</button>
                    </div>
                    <iframe id="browser-frame" class="browser-frame" src="https://duckduckgo.com/search?q=minecraft+web"></iframe>
                </div>

                <div id="tab-mc" class="os-tab hidden">
                    <div class="mc-container">
                        <div class="mc-top-nav">
                            <div class="mc-tab active">Java Edition</div>
                            <div class="mc-tab">Installations</div>
                            <div class="mc-tab" onclick="switchMC('skins')">Skins</div>
                        </div>
                        <div class="mc-main">
                            <div id="mc-skins-panel" class="hidden absolute inset-0 bg-[#2b2b2b] p-8 flex flex-col items-center">
                                <div id="skin-viewer" style="width:300px; height:350px; background:rgba(0,0,0,0.5); border-radius:10px;"></div>
                                <button onclick="document.getElementById('skin-up').click()" class="mt-4 bg-white text-black px-10 py-2 font-black text-[10px] uppercase">Upload PNG</button>
                                <input type="file" id="skin-up" class="hidden" onchange="loadSkin(this)">
                            </div>
                            <div class="mc-footer">
                                <div class="text-white font-bold text-xs">Forge-Redline v1.12.2</div>
                                <button class="play-btn" onclick="launchGame('mc')">PLAY</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="tab-repo" class="os-tab hidden">
                    <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-700" onclick="window.open('https://github.com/givvgivv21/LEARNING-WITH-ASIAN-CALCULATOR/tree/main', '_blank')">
                        <h2 class="text-2xl font-black mb-2">Source Root</h2>
                        <p class="text-zinc-500 font-mono text-sm mb-4">givvgivv21/LEARNING-WITH-ASIAN-CALCULATOR</p>
                        <div class="bg-black p-4 rounded text-blue-400 font-mono text-xs">
                            [System] Sync verified with main branch. Stealth kernel loaded.
                        </div>
                    </div>
                </div>

                <div id="tab-bt" class="os-tab hidden">
                    <div class="bg-zinc-900 border-2 border-orange-600 rounded-2xl p-16 text-center">
                        <h2 class="text-5xl font-black text-orange-500 mb-2 italic uppercase">Brotato Arena</h2>
                        <button class="bg-orange-600 text-white px-16 py-6 rounded-lg font-black text-xl mt-6" onclick="launchGame('bt')">ENTER WAVE</button>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        let is2nd = false; let input = "0"; let skinViewer; let history = [];
        
        window.onload = () => {
            skinViewer = new skinview3d.SkinViewer({ canvas: document.getElementById("skin-viewer"), width: 300, height: 350, skin: "https://minotar.net/skin/char" });
            skinViewer.autoRotate = true; skinViewer.animation = new skinview3d.WalkingAnimation();
        };

        function navigateBrowser() {
            const val = document.getElementById('browser-input').value;
            const frame = document.getElementById('browser-frame');
            if (val.includes('.') || val.includes('://')) {
                frame.src = val.startsWith('http') ? val : 'https://' + val;
            } else {
                frame.src = `https://duckduckgo.com/?q=${encodeURIComponent(val)}`;
            }
        }

        function launchGame(type) {
            const url = type === 'mc' ? 'https://takaiwebsite.neocities.org/minecraft' : 'https://raw.githack.com/Blobby-Boi/Brotato/main/index.html';
            const win = window.open("about:blank", "_blank", "width=1280,height=720");
            win.document.write(`<html><body style="margin:0;background:#000;"><iframe src="${url}" style="width:100vw;height:100vh;border:none;" allow="autoplay; fullscreen; gamepad; pointer-lock"></iframe></body></html>`);
        }

        function handleEnter() {
            if(is2nd) { openOS(); toggle2nd(); } 
            else {
                try {
                    const res = eval(input.replace('×','*').replace('÷','/'));
                    history.push(`${input} = ${res}`);
                    document.getElementById('history').innerHTML = history.slice(-5).join('<br>');
                    input = String(res);
                    document.getElementById('calc-val').innerText = input;
                } catch { document.getElementById('calc-val').innerText = "Error"; }
            }
        }

        function switchMC(v) { document.getElementById('mc-skins-panel').classList.toggle('hidden', v !== 'skins'); }
        function loadSkin(inp) { if (inp.files && inp.files[0]) { const r = new FileReader(); r.onload = (e) => skinViewer.loadSkin(e.target.result); r.readAsDataURL(inp.files[0]); } }
        function downloadSelf() { const b = new Blob([document.documentElement.outerHTML], {type: "text/html"}); const a = document.createElement("a"); a.href = URL.createObjectURL(b); a.download = "Rems_Corner_v18.html"; a.click(); }
        function toggle2nd() { is2nd = !is2nd; document.getElementById('btn-2nd').classList.toggle('key-active', is2nd); }
        function append(v) { input = input === "0" ? v : input + v; document.getElementById('calc-val').innerText = input; }
        function deleteChar() { input = input.slice(0, -1) || "0"; document.getElementById('calc-val').innerText = input; }
        function handleClear() { input = "0"; document.getElementById('calc-val').innerText = "0"; }
        function handleTuff() { if(is2nd) { openOS(); showTab('mc'); toggle2nd(); } else append('/'); }
        function openOS() { document.getElementById('rem-os').style.display = 'flex'; }
        function closeOS() { document.getElementById('rem-os').style.display = 'none'; }
        function showTab(t) { document.querySelectorAll('.os-tab').forEach(x => x.classList.add('hidden')); document.getElementById('tab-'+t).classList.remove('hidden'); }
    </script>
</body>
</html>
