<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>RemOS v24.0 | GitHub Absolute</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/skinview3d@3.0.0/dist/skinview3d.bundle.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --gh-black: #010409; --gh-dark: #0d1117; --gh-gray: #30363d; --accent: #f0883e; --thick-border: 10px solid #21262d; }
        body { background: var(--gh-black); color: #c9d1d9; font-family: 'JetBrains Mono', monospace; margin: 0; overflow: hidden; height: 100vh; }
        
        /* BULKY BRUTALIST UI */
        .industrial-frame { border: var(--thick-border); box-shadow: 15px 15px 0px #000; background: var(--gh-dark); border-radius: 2px; }
        .calc-bezel { border: 12px solid #30363d; background: #161b22; box-shadow: 20px 20px 0px rgba(0,0,0,0.8); }
        .btn-bulky { background: #21262d; border: 4px solid #484f58; box-shadow: 6px 6px 0px #000; transition: 0.05s; font-weight: 900; text-transform: uppercase; }
        .btn-bulky:active { transform: translate(4px, 4px); box-shadow: 0px 0px 0px #000; }
        
        /* TERMINAL STYLE */
        .terminal-display { background: #000; border: 4px inset #30363d; padding: 25px; color: var(--accent); font-size: 3rem; text-align: right; text-shadow: 0 0 10px var(--accent); }
        
        /* OS OVERLAY */
        #rem-os { position: fixed; inset: 0; background: var(--gh-black); z-index: 9999; display: none; padding: 40px; grid-template-columns: 350px 1fr; gap: 40px; }
        .os-tab { display: none; height: 100%; flex-direction: column; }
        .active-tab { display: flex; }

        /* BROWSER */
        .browser-box { flex: 1; display: flex; flex-direction: column; background: #fff; border: 8px solid var(--gh-gray); }
        .browser-nav { background: #161b22; padding: 18px; display: flex; gap: 15px; border-bottom: 6px solid var(--gh-gray); }
    </style>
</head>
<body onkeydown="if(event.key==='~'){panic()}">

    <div class="flex h-screen items-center justify-center p-16 gap-16">
        
        <div class="industrial-frame w-[400px] h-[700px] p-10 flex flex-col">
            <div class="border-b-4 border-gh-gray pb-6 mb-8">
                <h1 class="text-4xl font-black italic">REMS_OS <span class="text-orange-500">v24</span></h1>
                <p class="text-[10px] text-zinc-500 mt-2 font-bold tracking-[0.2em]">CORE ARCHITECTURE: GITHUB_NATIVE</p>
            </div>
            
            <div id="sys-log" class="flex-1 overflow-y-auto font-mono text-[10px] space-y-2 opacity-70">
                <div class="text-green-500">[SYSTEM] Handshake with GitHub.io... OK</div>
                <div class="text-green-500">[SYSTEM] Bypassing X-Frame-Options... OK</div>
                <div class="text-white">[CMD] Loading Mechanical UI...</div>
                <div class="text-orange-400">[WARN] Panic Key: Tilde (~) Ready.</div>
            </div>

            <div class="mt-10 space-y-4">
                <button onclick="downloadSelf()" class="btn-bulky w-full py-5 bg-green-800 text-white text-xs">COMPILED_BUILD.ZIP</button>
                <div class="text-center text-[9px] text-zinc-600">UNBLOCKED_BY: GITHUB_CERTIFIED</div>
            </div>
        </div>

        <div class="calc-bezel p-10 w-[500px]">
            <div class="terminal-display mb-10" id="display">0</div>
            <div class="grid grid-cols-4 gap-5">
                <button id="mode-2nd" class="btn-bulky h-20 text-xs" onclick="toggle2nd()">2nd</button>
                <button class="btn-bulky h-20 text-xs" onclick="del()">DEL</button>
                <button class="btn-bulky h-20 text-xs" onclick="reset()">AC</button>
                <button class="btn-bulky h-20 text-orange-500 text-2xl" onclick="op('/')">÷</button>
                
                <button class="btn-bulky h-20 text-2xl" onclick="press('7')">7</button>
                <button class="btn-bulky h-20 text-2xl" onclick="press('8')">8</button>
                <button class="btn-bulky h-20 text-2xl" onclick="press('9')">9</button>
                <button class="btn-bulky h-20 text-orange-500 text-2xl" onclick="press('*')">×</button>
                
                <button class="btn-bulky h-20 text-2xl" onclick="press('4')">4</button>
                <button class="btn-bulky h-20 text-2xl" onclick="press('5')">5</button>
                <button class="btn-bulky h-20 text-2xl" onclick="press('6')">6</button>
                <button class="btn-bulky h-20 text-orange-500 text-2xl" onclick="press('-')">-</button>
                
                <button class="btn-bulky h-20 text-2xl" onclick="press('1')">1</button>
                <button class="btn-bulky h-20 text-2xl" onclick="press('2')">2</button>
                <button class="btn-bulky h-20 text-2xl" onclick="press('3')">3</button>
                <button class="btn-bulky h-20 text-orange-500 text-2xl" onclick="press('+')">+</button>
                
                <button class="btn-bulky h-20 text-2xl col-span-2" onclick="press('0')">0</button>
                <button class="btn-bulky h-20 text-2xl" onclick="press('.')">.</button>
                <button class="btn-bulky h-20 bg-orange-600 text-white border-none text-2xl" onclick="evalCalc()">=</button>
            </div>
        </div>
    </div>

    <div id="rem-os">
        <div class="industrial-frame p-10 flex flex-col gap-6">
            <div class="font-black text-center mb-10 border-b-4 border-gh-gray pb-6 text-xl">COMMAND_MATRIX</div>
            <button onclick="showTab('bt')" class="btn-bulky p-6 text-sm text-left text-orange-500">🥔 BROTATO (GITHUB_PAGES)</button>
            <button onclick="showTab('br')" class="btn-bulky p-6 text-sm text-left text-blue-400">🌐 BYPASS_BROWSER_v2</button>
            <button onclick="showTab('mc')" class="btn-bulky p-6 text-sm text-left">📦 MINECRAFT_FORGE</button>
            
            <div class="mt-auto p-6 bg-black border-4 border-gh-gray text-[10px] text-zinc-500 italic">
                > PROTOCOL: GITHUB_PAGES_SECURE<br>
                > STATUS: BYPASS_ACTIVE
            </div>
            <button onclick="closeOS()" class="btn-bulky bg-red-900/30 text-red-500 py-5 text-xs">TERMINATE_PROCESS</button>
        </div>

        <div class="flex flex-col">
            <div id="tab-br" class="os-tab active-tab flex flex-col">
                <div class="browser-box">
                    <div class="browser-nav">
                        <input type="text" id="url-input" class="flex-1 bg-black border-4 border-gh-gray rounded px-6 py-2 text-white text-xs font-bold" placeholder="Search Google-IGU (No Refusal) or type URL...">
                        <button onclick="goBrowser()" class="btn-bulky bg-blue-700 text-white px-10 text-[10px]">EXECUTE</button>
                    </div>
                    <iframe id="frame-browser" class="w-full h-full" src="https://www.google.com/search?q=unblocked+github+games&igu=1"></iframe>
                </div>
            </div>

            <div id="tab-bt" class="os-tab hidden flex-col items-center justify-center bg-[url('https://github.githubassets.com/images/modules/site/home-campaign/hero-bg.webp')] bg-cover">
                <div class="bg-black/90 p-20 border-[10px] border-gh-gray text-center shadow-2xl">
                    <h2 class="text-9xl font-black italic text-white mb-6">BROTATO</h2>
                    <p class="text-orange-500 font-mono text-sm mb-12 tracking-[0.4em]">DEPLOYED_ON: GITHUB.IO</p>
                    <button onclick="launch('bt')" class="btn-bulky bg-orange-600 text-white px-24 py-10 text-4xl hover:scale-105 transition">START_SESSION</button>
                </div>
            </div>

            <div id="tab-mc" class="os-tab hidden">
                <div class="industrial-frame flex-1 flex flex-col overflow-hidden relative">
                    <div id="skin-ui" class="absolute inset-0 bg-black/95 z-[100] hidden flex-col items-center justify-center p-10">
                        <div class="absolute top-10 right-10 text-6xl font-black text-red-600 cursor-pointer" onclick="toggleSkin(false)">[X]</div>
                        <div id="skin-vp" style="width:400px; height:500px; border:8px solid #30363d;"></div>
                        <button onclick="document.getElementById('sk-file').click()" class="btn-bulky mt-10 px-16 py-5 bg-white text-black">IMPORT_PNG_SOURCE</button>
                        <input type="file" id="sk-file" class="hidden" onchange="applySkin(this)">
                    </div>
                    <div class="bg-[#161b22] p-5 flex gap-10 text-xs font-black border-b-8 border-gh-gray">
                        <span class="text-white">STABLE_RELEASE</span>
                        <span class="cursor-pointer text-zinc-500 hover:text-white" onclick="toggleSkin(true)">SKIN_RECONSTRUCT</span>
                    </div>
                    <div class="flex-1 bg-[url('https://minecraft.net/content/dam/minecraftnet/games/minecraft/key-art/MC-Home-Hero-Desktop.jpg')] bg-cover flex items-end p-12">
                        <button onclick="launch('mc')" class="btn-bulky bg-[#3c8527] text-white w-full py-8 text-5xl">INITIALIZE_GAME</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let is2nd = false; let v = "0"; let skin;
        
        window.onload = () => {
            skin = new skinview3d.SkinViewer({ canvas: document.getElementById("skin-vp"), width: 400, height: 500, skin: "https://minotar.net/skin/char" });
            skin.autoRotate = true;
        };

        function goBrowser() {
            const query = document.getElementById('url-input').value;
            const f = document.getElementById('frame-browser');
            // Check if it's a URL or a search
            if (query.includes('.') && !query.includes(' ')) {
                // If they type a URL, we attempt to open it in a NEW WINDOW to avoid frame blocking
                window.open(query.startsWith('http') ? query : 'https://' + query, '_blank');
            } else {
                // If it's a search, use Google IGU which allows frames
                f.src = `https://www.google.com/search?q=${encodeURIComponent(query)}&igu=1`;
            }
        }

        function launch(t) {
            // BROTATO NATIVE GITHUB PAGES: This is the most unblocked version possible.
            const url = t === 'mc' ? 'https://takaiwebsite.neocities.org/minecraft' : 'https://blobby-boi.github.io/Brotato/';
            window.open("about:blank", "_blank", "width=1280,height=720").document.write(`<html><body style="margin:0;background:#000;"><iframe src="${url}" style="width:100vw;height:100vh;border:none;" allow="autoplay; fullscreen; gamepad; pointer-lock"></iframe></body></html>`);
        }

        function toggleSkin(s) { document.getElementById('skin-ui').style.display = s ? 'flex' : 'none'; }
        function applySkin(i) { if (i.files && i.files[0]) { const r = new FileReader(); r.onload = (e) => skin.loadSkin(e.target.result); r.readAsDataURL(i.files[0]); } }
        function panic() { closeOS(); reset(); }
        function downloadSelf() { const b = new Blob([document.documentElement.outerHTML], {type: "text/html"}); const a = document.createElement("a"); a.href = URL.createObjectURL(b); a.download = "RemsOS_v24.html"; a.click(); }
        
        function toggle2nd() { is2nd = !is2nd; document.getElementById('mode-2nd').style.background = is2nd ? '#f0883e' : '#21262d'; }
        function press(n) { v = (v === "0" ? n : v + n); document.getElementById('display').innerText = v; }
        function del() { v = v.slice(0, -1) || "0"; document.getElementById('display').innerText = v; }
        function reset() { v = "0"; document.getElementById('display').innerText = "0"; }
        function op(o) { if(is2nd && o === '/') { openOS(); showTab('mc'); toggle2nd(); } else press(o); }
        function evalCalc() { if(is2nd) { openOS(); toggle2nd(); } else { try { v = String(eval(v.replace('×','*').replace('÷','/'))); document.getElementById('display').innerText = v; } catch { document.getElementById('display').innerText = "ERR"; } } }
        
        function openOS() { document.getElementById('rem-os').style.display = 'grid'; }
        function closeOS() { document.getElementById('rem-os').style.display = 'none'; }
        function showTab(t) { document.querySelectorAll('.os-tab').forEach(x => x.classList.remove('active-tab')); document.getElementById('tab-'+t).classList.add('active-tab'); }
    </script>
</body>
</html>
