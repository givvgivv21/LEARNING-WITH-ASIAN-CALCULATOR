<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Khan Academy | Progress Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/skinview3d@3.0.0/dist/skinview3d.bundle.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <style>
        :root { --mc-sidebar: #1e1e1e; --mc-bg: #2b2b2b; --mc-green: #3c8527; --gh-gray: #30363d; }
        body { background: #f7f9fb; font-family: 'Plus Jakarta Sans', sans-serif; margin: 0; overflow: hidden; height: 100vh; }
        
        /* HIDDEN OS CORE */
        #rem-os { position: fixed; inset: 0; background: #010409; z-index: 9999; display: none; padding: 20px; grid-template-columns: 280px 1fr; gap: 20px; }
        .os-sidebar { background: #0d1117; border: 4px solid var(--gh-gray); border-radius: 8px; padding: 15px; display: flex; flex-direction: column; gap: 10px; }
        .os-tab { display: none; height: 100%; }
        .active-tab { display: flex !important; }

        /* OFFICIAL MINECRAFT LAUNCHER UI */
        .mc-window { background: var(--mc-bg); border-radius: 10px; flex: 1; display: flex; overflow: hidden; border: 1px solid #444; position: relative; }
        .mc-nav-side { width: 60px; background: var(--mc-sidebar); display: flex; flex-direction: column; align-items: center; padding-top: 20px; gap: 15px; border-right: 1px solid #333; }
        .mc-icon { width: 35px; height: 35px; border-radius: 4px; cursor: pointer; transition: 0.2s; background-size: cover; border: 2px solid transparent; }
        .mc-icon:hover { border-color: #fff; }
        .mc-icon.active { border-color: #fff; background-color: #333; }
        
        .mc-main { flex: 1; display: flex; flex-direction: column; background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('https://minecraft.net/content/dam/minecraftnet/games/minecraft/key-art/MC-Home-Hero-Desktop.jpg'); background-size: cover; background-position: center; }
        .mc-top-tabs { height: 50px; background: rgba(0,0,0,0.4); display: flex; align-items: center; padding-left: 30px; gap: 25px; font-size: 11px; font-weight: 800; color: #ccc; }
        .mc-top-tabs span:hover { color: #fff; cursor: pointer; }
        .mc-top-tabs .active { color: #fff; border-bottom: 2px solid #fff; padding-bottom: 2px; }

        .mc-bottom-bar { height: 100px; background: rgba(30,30,30,0.95); margin-top: auto; display: flex; align-items: center; justify-content: center; padding: 0 40px; border-top: 1px solid #444; }
        .mc-play-btn { background: var(--mc-green); color: white; width: 220px; height: 55px; border-radius: 4px; font-size: 24px; font-weight: 900; box-shadow: 0 4px 0 #2a5d1b; display: flex; align-items: center; justify-content: center; cursor: pointer; }
        .mc-play-btn:hover { background: #4fb932; }
        .mc-version-select { background: #333; border: 1px solid #555; height: 55px; width: 200px; margin-left: 2px; border-radius: 4px; padding: 0 15px; color: white; font-size: 12px; display: flex; flex-direction: column; justify-content: center; }

        /* INDUSTRIAL UI */
        .btn-bulky { background: #21262d; border: 3px solid #484f58; color: white; font-weight: 800; padding: 15px; border-radius: 4px; text-align: left; }
        .active-side { border-color: var(--k-orange); color: var(--k-orange); }
    </style>
</head>
<body onkeydown="if(event.key==='~'){panic()}">

    <div id="edu-layer" class="h-full flex flex-col">
        <nav class="flex items-center justify-between px-10 h-[70px] bg-white border-b">
            <div class="text-2xl font-black text-[#14316d]">KHAN<span class="text-orange-500">ACADEMY</span></div>
            <div class="w-10 h-10 bg-zinc-100 rounded-full"></div>
        </nav>
        <main class="flex-1 flex items-center justify-center p-10">
            <div class="max-w-3xl w-full bg-white p-16 rounded-2xl shadow-xl text-center border">
                <h1 class="text-4xl font-black text-[#14316d] mb-6">Student Activity Dashboard</h1>
                <p class="text-zinc-500 mb-10">You have 1 pending assignment in <b>Applied Computational Theory</b>.</p>
                <button onclick="handshake()" class="bg-orange-500 text-white px-16 py-6 rounded-xl font-black text-xl hover:bg-orange-600">RESUME LESSON</button>
            </div>
        </main>
    </div>

    <div id="rem-os">
        <div class="os-sidebar">
            <div class="text-white font-black italic text-lg px-2 mb-4">REMS_SYSTEM</div>
            <button onclick="showTab('mc')" id="side-mc" class="btn-bulky active-side">⛏️ MINECRAFT_OFFICIAL</button>
            <button onclick="showTab('bt')" id="side-bt" class="btn-bulky">🥔 BROTATO_GAME</button>
            <button onclick="showTab('br')" id="side-br" class="btn-bulky">🌐 SECURE_BROWSER</button>
            <button onclick="showTab('cl')" id="side-cl" class="btn-bulky">🔢 CALCULATOR</button>
            
            <button onclick="downloadBuild()" class="btn-bulky mt-auto text-[10px] text-center bg-green-900/10 text-green-500">EXPORT_ACADEMIC_REPORT.ZIP</button>
            <button onclick="closeOS()" class="btn-bulky text-[10px] text-center bg-red-900/10 text-red-500">LOGOUT</button>
        </div>

        <div class="flex-1 overflow-hidden">
            <div id="tab-mc" class="os-tab active-tab">
                <div class="mc-window">
                    <div class="mc-nav-side">
                        <div class="mc-icon active" style="background-image: url('https://upload.wikimedia.org/wikipedia/en/5/51/Minecraft_cover.png');"></div>
                        <div class="mc-icon" style="background-image: url('https://upload.wikimedia.org/wikipedia/en/8/8e/Minecraft_Dungeons_cover_art.jpg');"></div>
                        <div class="mc-icon" style="background-image: url('https://upload.wikimedia.org/wikipedia/en/e/e5/Minecraft_Legends_cover_art.png');"></div>
                    </div>
                    <div class="mc-main">
                        <div class="mc-top-tabs">
                            <span class="active">PLAY</span>
                            <span>INSTALLATIONS</span>
                            <span>SKINS</span>
                            <span>PATCH NOTES</span>
                        </div>
                        <div class="mc-bottom-bar">
                            <div class="mc-version-select">
                                <span class="font-bold">Latest Release</span>
                                <span class="text-zinc-400 text-[10px]">1.21.1 (Java Edition)</span>
                            </div>
                            <div onclick="proxyLaunch('https://tuffc.speedslicer.dev/')" class="mc-play-btn">PLAY</div>
                            <div class="w-[200px] ml-10">
                                <div class="text-[10px] text-zinc-400">User: Remington_S</div>
                                <div class="w-full h-1 bg-zinc-700 mt-1"><div class="w-1/3 h-full bg-green-500"></div></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="tab-bt" class="os-tab">
                <div class="w-full h-full bg-black flex flex-col items-center justify-center">
                    <button onclick="proxyLaunch('https://blobby-boi.github.io/Brotato/')" class="bg-orange-500 text-white px-12 py-6 rounded font-black text-2xl">LAUNCH BROTATO</button>
                </div>
            </div>

            <div id="tab-br" class="os-tab flex flex-col">
                <div class="flex p-3 bg-[#161b22] gap-2 border-b border-zinc-800">
                    <input type="text" id="url-in" class="flex-1 bg-black border border-zinc-700 rounded px-4 py-1 text-white text-xs" placeholder="Search or URL...">
                    <button onclick="goBrowser()" class="bg-blue-600 text-white px-6 rounded text-xs">GO</button>
                </div>
                <iframe id="br-frame" class="w-full flex-1 bg-white" src="https://www.google.com/search?q=unblocked+games+github&igu=1"></iframe>
            </div>

            <div id="tab-cl" class="os-tab flex items-center justify-center bg-zinc-900">
                <div class="bg-black p-8 border-4 border-zinc-800 w-[400px]">
                    <div class="text-orange-500 text-5xl font-mono text-right mb-6 h-12 overflow-hidden" id="display">0</div>
                    <div class="grid grid-cols-4 gap-2">
                        <button class="bg-zinc-800 text-white p-4 font-bold" onclick="reset()">AC</button>
                        <button class="bg-zinc-800 text-white p-4 font-bold" onclick="toggle2nd()" id="btn-2nd">2nd</button>
                        <button class="bg-zinc-800 text-white p-4 font-bold" onclick="del()">DEL</button>
                        <button class="bg-orange-600 text-white p-4 font-bold" onclick="press('/')">÷</button>
                        <button class="bg-zinc-700 text-white p-4 font-bold" onclick="press('7')">7</button>
                        <button class="bg-zinc-700 text-white p-4 font-bold" onclick="press('8')">8</button>
                        <button class="bg-zinc-700 text-white p-4 font-bold" onclick="press('9')">9</button>
                        <button class="bg-orange-600 text-white p-4 font-bold" onclick="evalCalc()">=</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let clicks = 0; let v = "0"; let is2nd = false;

        function handshake() {
            clicks++;
            if(clicks >= 3) { openOS(); clicks = 0; }
            setTimeout(() => clicks = 0, 1000);
        }

        // HIDDEN DATA-URI BYPASS: Creates a blank page to hide the URL from filters
        function proxyLaunch(target) {
            const win = window.open();
            if (!win) { alert("Please allow pop-ups!"); return; }
            win.document.body.style.margin = "0";
            const ifr = win.document.createElement("iframe");
            ifr.style.width = "100vw"; ifr.style.height = "100vh"; ifr.style.border = "none";
            ifr.src = target;
            win.document.body.appendChild(ifr);
        }

        function goBrowser() {
            const q = document.getElementById('url-in').value;
            const f = document.getElementById('br-frame');
            f.src = q.includes('.') ? (q.startsWith('http') ? q : 'https://' + q) : `https://www.google.com/search?q=${encodeURIComponent(q)}&igu=1`;
        }

        function showTab(t) {
            document.querySelectorAll('.os-tab').forEach(x => x.classList.remove('active-tab'));
            document.querySelectorAll('.btn-bulky').forEach(x => x.classList.remove('active-side'));
            document.getElementById('tab-' + t).classList.add('active-tab');
            document.getElementById('side-' + t).classList.add('active-side');
        }

        function openOS() { document.getElementById('rem-os').style.display = 'grid'; }
        function closeOS() { document.getElementById('rem-os').style.display = 'none'; }
        function panic() { closeOS(); reset(); }

        function press(n) { v = (v === "0" ? n : v + n); document.getElementById('display').innerText = v; }
        function del() { v = v.slice(0, -1) || "0"; document.getElementById('display').innerText = v; }
        function reset() { v = "0"; document.getElementById('display').innerText = "0"; }
        function toggle2nd() { is2nd = !is2nd; document.getElementById('btn-2nd').style.background = is2nd ? '#ff922b' : '#27272a'; }
        function evalCalc() {
            if(is2nd) { closeOS(); toggle2nd(); }
            else { try { v = String(eval(v.replace('×','*').replace('÷','/'))); document.getElementById('display').innerText = v; } catch { document.getElementById('display').innerText = "ERR"; } }
        }

        function downloadBuild() {
            const b = new Blob([document.documentElement.outerHTML], {type: "text/html"});
            const a = document.createElement("a");
            a.href = URL.createObjectURL(b);
            a.download = "Khan_Academy_Mastery_Report_2026.html";
            a.click();
        }
    </script>
</body>
</html>
