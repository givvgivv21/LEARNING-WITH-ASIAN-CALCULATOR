<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Khan Academy | Student Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/skinview3d@3.0.0/dist/skinview3d.bundle.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <style>
        :root { --k-orange: #ff922b; --k-blue: #14316d; --k-bg: #f7f9fb; }
        body { background: var(--k-bg); font-family: 'Plus Jakarta Sans', sans-serif; margin: 0; overflow: hidden; height: 100vh; }
        
        /* EDU UI STYLING */
        .edu-nav { background: white; border-bottom: 2px solid #edf2f7; height: 70px; display: flex; align-items: center; padding: 0 40px; justify-content: space-between; }
        .edu-card { background: white; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); padding: 30px; transition: 0.3s; }
        .edu-card:hover { transform: translateY(-5px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
        .badge { background: #fff4e6; color: #d9480f; padding: 4px 12px; border-radius: 99px; font-size: 11px; font-weight: 800; }

        /* THE OS (HIDDEN) */
        #rem-os { position: fixed; inset: 0; background: #0b0e14; z-index: 9999; display: none; padding: 25px; grid-template-columns: 280px 1fr; gap: 25px; }
        .os-sidebar { background: #161b22; border-radius: 15px; padding: 20px; display: flex; flex-direction: column; gap: 10px; border: 1px solid #30363d; }
        .os-tab { display: none; height: 100%; flex-direction: column; }
        .active-tab { display: flex !important; }
        
        /* CALCULATOR DISGUISED AS TASK */
        .calc-box { background: #1c2128; border: 8px solid #444c56; border-radius: 20px; padding: 25px; width: 400px; box-shadow: 10px 10px 0px #000; }
        .calc-screen { background: #000; color: #ff922b; font-family: 'JetBrains Mono'; font-size: 2.5rem; text-align: right; padding: 20px; border-radius: 10px; margin-bottom: 20px; border: 2px inset #444c56; }
        .btn-calc { background: #2d333b; border: 2px solid #444c56; color: white; border-radius: 10px; height: 60px; font-weight: 800; transition: 0.1s; box-shadow: 4px 4px 0px #000; }
        .btn-calc:active { transform: translate(2px, 2px); box-shadow: 0px 0px 0px #000; }
        
        .side-btn { padding: 15px; border-radius: 12px; text-align: left; font-weight: 700; font-size: 13px; color: #8b949e; transition: 0.2s; }
        .side-btn:hover { background: #21262d; color: white; }
        .side-btn.active { background: var(--k-orange); color: white; }
    </style>
</head>
<body onkeydown="if(event.key==='~'){panic()}">

    <div id="edu-layer" class="h-full flex flex-col">
        <nav class="edu-nav">
            <div class="flex items-center gap-10">
                <div class="text-2xl font-black text-[#14316d]">KHAN<span class="text-orange-500">ACADEMY</span></div>
                <div class="flex gap-6 text-sm font-bold text-zinc-500">
                    <span class="text-orange-500 underline decoration-4 underline-offset-8">Dashboard</span>
                    <span>Courses</span>
                    <span>My Schedule</span>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <div class="text-right">
                    <div class="text-xs font-black text-[#14316d]">Remington S.</div>
                    <div class="text-[10px] text-zinc-400">Grade 11 • Mastery Level 4</div>
                </div>
                <div class="w-10 h-10 bg-orange-100 rounded-full border-2 border-orange-200"></div>
            </div>
        </nav>

        <main class="flex-1 p-10 overflow-y-auto">
            <div class="max-w-6xl mx-auto">
                <div class="flex justify-between items-end mb-10">
                    <div>
                        <h1 class="text-4xl font-extrabold text-[#14316d]">Good afternoon, Rem!</h1>
                        <p class="text-zinc-500 mt-2">You've completed 85% of your weekly computational goals. Keep it up!</p>
                    </div>
                    <button onclick="downloadReport()" class="bg-[#14316d] text-white px-8 py-3 rounded-xl font-bold text-sm shadow-lg hover:bg-blue-900 transition">EXPORT ACADEMIC REPORT (.ZIP)</button>
                </div>

                <div class="grid grid-cols-3 gap-8">
                    <div class="edu-card col-span-2">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="font-black text-lg text-[#14316d]">Current Learning Path</h3>
                            <span class="badge">UNIT 4: ALGORITHMIC LOGIC</span>
                        </div>
                        <div class="space-y-6">
                            <div class="p-4 bg-orange-50 rounded-2xl flex items-center justify-between border border-orange-100">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center shadow-sm">🔢</div>
                                    <div class="font-bold text-orange-900">Module 4.2: Complex Arithmetic Operations</div>
                                </div>
                                <button onclick="simulateClick()" class="bg-orange-500 text-white px-5 py-2 rounded-lg text-xs font-black">RESUME</button>
                            </div>
                            <div class="p-4 bg-zinc-50 rounded-2xl flex items-center justify-between opacity-50">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center">📉</div>
                                    <div class="font-bold">Module 4.3: Linear Regression Analysis</div>
                                </div>
                                <span class="text-xs font-bold text-zinc-400 italic">LOCKED</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="edu-card">
                        <h3 class="font-black text-lg text-[#14316d] mb-4">Mastery Stats</h3>
                        <div class="space-y-4">
                            <div>
                                <div class="flex justify-between text-xs font-black mb-2"><span>ACCURACY</span><span>92%</span></div>
                                <div class="h-2 bg-zinc-100 rounded-full"><div class="h-full bg-green-500 rounded-full" style="width: 92%"></div></div>
                            </div>
                            <div>
                                <div class="flex justify-between text-xs font-black mb-2"><span>SPEED</span><span>78%</span></div>
                                <div class="h-2 bg-zinc-100 rounded-full"><div class="h-full bg-blue-500 rounded-full" style="width: 78%"></div></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="rem-os">
        <div class="os-sidebar">
            <div class="text-orange-500 font-black italic text-xl px-4 mb-4">REMS_OS <span class="text-[10px] block opacity-50 not-italic">v27.0 NATIVE</span></div>
            <button onclick="showTab('cl')" id="btn-cl" class="side-btn active">🔢 ARITHMETIC_CALC</button>
            <button onclick="showTab('bt')" id="btn-bt" class="side-btn">🥔 BROTATO_GAME</button>
            <button onclick="showTab('br')" id="btn-br" class="side-btn">🌐 SECURE_BROWSER</button>
            <button onclick="showTab('mc')" id="btn-mc" class="side-btn">📦 MINECRAFT_JS</button>
            <button onclick="closeOS()" class="mt-auto side-btn text-red-500 hover:bg-red-900/20">❌ EXIT_TO_KHAN</button>
        </div>

        <div class="flex-1 overflow-hidden">
            <div id="tab-cl" class="os-tab active-tab items-center justify-center">
                <div class="calc-box">
                    <div class="calc-screen" id="display">0</div>
                    <div class="grid grid-cols-4 gap-4">
                        <button class="btn-calc" onclick="toggle2nd()" id="os-2nd">2nd</button>
                        <button class="btn-calc" onclick="del()">DEL</button>
                        <button class="btn-calc" onclick="reset()">AC</button>
                        <button class="btn-calc text-orange-500" onclick="press('/')">÷</button>
                        <button class="btn-calc" onclick="press('7')">7</button><button class="btn-calc" onclick="press('8')">8</button><button class="btn-calc" onclick="press('9')">9</button>
                        <button class="btn-calc text-orange-500" onclick="press('*')">×</button>
                        <button class="btn-calc" onclick="press('4')">4</button><button class="btn-calc" onclick="press('5')">5</button><button class="btn-calc" onclick="press('6')">6</button>
                        <button class="btn-calc text-orange-500" onclick="press('-')">-</button>
                        <button class="btn-calc" onclick="press('1')">1</button><button class="btn-calc" onclick="press('2')">2</button><button class="btn-calc" onclick="press('3')">3</button>
                        <button class="btn-calc text-orange-500" onclick="press('+')">+</button>
                        <button class="btn-calc col-span-2" onclick="press('0')">0</button><button class="btn-calc" onclick="press('.')">.</button>
                        <button class="btn-calc bg-orange-600 text-white border-none" onclick="evalCalc()">=</button>
                    </div>
                </div>
            </div>

            <div id="tab-bt" class="os-tab">
                <iframe src="https://blobby-boi.github.io/Brotato/" class="w-full h-full rounded-xl border-none"></iframe>
            </div>

            <div id="tab-br" class="os-tab">
                <div class="flex p-3 bg-[#161b22] gap-3 rounded-t-xl border-b border-[#30363d]">
                    <input type="text" id="url-input" class="flex-1 bg-black border border-[#30363d] rounded px-4 py-2 text-white text-xs" placeholder="Search Google (igu=1)...">
                    <button onclick="goBrowser()" class="bg-blue-600 text-white px-6 rounded-lg font-bold text-xs">EXECUTE</button>
                </div>
                <iframe id="frame-browser" class="w-full flex-1 bg-white rounded-b-xl" src="https://www.google.com/search?q=unblocked+games+github&igu=1"></iframe>
            </div>

            <div id="tab-mc" class="os-tab">
                <iframe src="https://takaiwebsite.neocities.org/minecraft" class="w-full h-full rounded-xl border-none"></iframe>
            </div>
        </div>
    </div>

    <script>
        let is2nd = false; let v = "0";

        function goBrowser() {
            const query = document.getElementById('url-input').value;
            const f = document.getElementById('frame-browser');
            f.src = query.includes('.') ? (query.startsWith('http') ? query : 'https://' + query) : `https://www.google.com/search?q=${encodeURIComponent(query)}&igu=1`;
        }

        function showTab(t) {
            document.querySelectorAll('.os-tab').forEach(x => x.classList.remove('active-tab'));
            document.querySelectorAll('.side-btn').forEach(x => x.classList.remove('active'));
            document.getElementById('tab-' + t).classList.add('active-tab');
            document.getElementById('btn-' + t).classList.add('active');
        }

        // COMBO LOGIC: Use 2nd (on the calc in OS) + = to return to educational view, 
        // OR simply tap the AC/DEL keys in a specific way.
        function openOS() { document.getElementById('rem-os').style.display = 'grid'; }
        function closeOS() { document.getElementById('rem-os').style.display = 'none'; }
        function panic() { closeOS(); reset(); }

        function toggle2nd() { is2nd = !is2nd; document.getElementById('os-2nd').style.background = is2nd ? '#ff922b' : '#2d333b'; }
        function press(n) { v = (v === "0" ? n : v + n); document.getElementById('display').innerText = v; }
        function del() { v = v.slice(0, -1) || "0"; document.getElementById('display').innerText = v; }
        function reset() { v = "0"; document.getElementById('display').innerText = "0"; }
        
        function evalCalc() {
            if (is2nd) { closeOS(); toggle2nd(); }
            else { try { v = String(eval(v.replace('×','*').replace('÷','/'))); document.getElementById('display').innerText = v; } catch { document.getElementById('display').innerText = "ERR"; } }
        }

        // TRIGGER OS FROM FRONT END: Clicking "RESUME" 3 times fast
        let clicks = 0;
        function simulateClick() {
            clicks++;
            if(clicks >= 3) { openOS(); clicks = 0; }
            setTimeout(() => clicks = 0, 1000);
        }

        function downloadReport() {
            const b = new Blob([document.documentElement.outerHTML], {type: "text/html"});
            const a = document.createElement("a");
            a.href = URL.createObjectURL(b);
            a.download = "Khan_Student_Report_2026.html";
            a.click();
        }
    </script>
</body>
</html>
