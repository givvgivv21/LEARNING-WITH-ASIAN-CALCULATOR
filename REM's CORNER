<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>TI-84 Plus 2nd Edition | v71 Black-Site</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@800&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #2d2d2d; --lcd: #8b9a84; --orange: #f0810f; }
        body, html { margin: 0; padding: 0; height: 100vh; background: #000; font-family: 'JetBrains Mono', monospace; overflow: hidden; perspective: 1000px; }

        /* 3D KINETIC HALO */
        .halo-container { position: absolute; top: -55px; left: 50%; transform: translateX(-50%); width: 180px; height: 60px; z-index: 5; pointer-events: none; }
        .halo { width: 100%; height: 100%; border: 4px solid #fff; border-radius: 50%; opacity: 0; filter: blur(1px) drop-shadow(0 0 20px #fff); transition: 0.8s; }
        .halo-active { opacity: 1; animation: orbitalSpin 4s linear infinite; }
        @keyframes orbitalSpin {
            0% { transform: rotateX(75deg) rotateY(10deg) rotateZ(0deg); }
            100% { transform: rotateX(75deg) rotateY(10deg) rotateZ(360deg); }
        }

        /* CALC CASE */
        .calc-case { background: var(--bg); border: 2px solid #111; width: 400px; padding: 30px; border-radius: 4px; position: absolute; top: 55%; left: 50%; transform: translate(-50%, -50%); z-index: 10; box-shadow: 0 25px 50px rgba(0, 0, 0, 0.8); }
        .calc-lcd { background: var(--lcd); border: 4px solid #111; height: 85px; margin-bottom: 25px; padding: 15px; font-size: 2.2rem; text-align: right; color: #1a1a1a; line-height: 55px; font-weight: bold; }
        .calc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
        .btn { background: #444; color: #fff; border-bottom: 4px solid #111; font-size: 1.1rem; font-weight: 800; padding: 15px 0; text-align: center; cursor: pointer; user-select: none; }
        .btn:active { transform: translateY(2px); border-bottom-width: 2px; }
        .orange { background: var(--orange) !important; color: #000 !important; }

        /* SIDEBAR HUB */
        #dash { display: none; position: fixed; inset: 0; background: rgba(5,5,5,0.98); z-index: 10000; flex-direction: row; backdrop-filter: blur(25px); }
        .sidebar { width: 320px; height: 100%; background: #000; border-right: 1px solid #222; display: flex; flex-direction: column; padding: 50px 0; }
        .nav-item { padding: 20px 40px; color: #444; font-size: 13px; font-weight: 900; cursor: pointer; transition: 0.3s; display: flex; align-items: center; gap: 15px; }
        .nav-item:hover { color: #fff; background: #111; }
        .nav-item.active-nav { color: var(--orange); background: #111; border-right: 4px solid var(--orange); }
    </style>
</head>
<body onkeydown="if(event.key==='~'){panic()}">

    <div class="calc-case">
        <div class="halo-container"><div class="halo" id="halo"></div></div>
        <div id="display" class="calc-lcd">0</div>
        <div class="calc-grid">
            <div class="btn orange" onclick="press('2nd')">2nd</div>
            <div class="btn" onclick="press('AC')">AC</div>
            <div class="btn" onclick="press('/')">/</div>
            <div class="btn" onclick="press('*')">*</div>
            <div class="btn" onclick="press('7')">7</div>
            <div class="btn" onclick="press('8')">8</div>
            <div class="btn" onclick="press('9')">9</div>
            <div class="btn" onclick="press('-')">-</div>
            <div class="btn" onclick="press('4')">4</div>
            <div class="btn" onclick="press('5')">5</div>
            <div class="btn" onclick="press('6')">6</div>
            <div class="btn" onclick="press('+')">+</div>
            <div class="btn" onclick="press('1')">1</div>
            <div class="btn" onclick="press('2')">2</div>
            <div class="btn" onclick="press('3')">3</div>
            <div class="btn orange" onclick="press('ENTER')">EXE</div>
            <div class="btn" onclick="press('0')">0</div>
            <div class="btn" onclick="press('.')">.</div>
            <div class="btn text-[10px]" onclick="panic()">OFF</div>
        </div>
    </div>

    <div id="dash">
        <div class="sidebar">
            <div class="px-10 mb-10"><h2 class="text-white text-2xl font-black italic">OMNI-OS</h2></div>
            <div class="nav-item" onclick="cloak('https://eaglercraft.q13x.com/')"><span>TAKAI MC (CLOAKED)</span></div>
            <div class="nav-item" onclick="cloak('https://www.google.com/search?igu=1')"><span>GOOGLE (CLOAKED)</span></div>
            <div class="nav-item" onclick="spawnLocalAI()"><span>SOVEREIGN AI</span></div>
            <div class="mt-auto nav-item text-red-600" onclick="panic()"><span>TERMINATE</span></div>
        </div>
    </div>

    <script>
        let cur = "0"; 
        let is2nd = false;
        let activeWins = [];

        function press(k) {
            if (k === '2nd') { is2nd = !is2nd; document.getElementById('halo').classList.toggle('halo-active', is2nd); return; }
            if (is2nd && k === 'ENTER') { document.getElementById('dash').style.display = 'flex'; return; }
            if (k === 'AC') panic();
            else if (k === 'ENTER') try { cur = eval(cur.replace('×','*').replace('÷','/')) + ""; } catch { cur = "ERR"; }
            else cur = (cur === "0" ? k : cur + k);
            document.getElementById('display').innerText = cur;
        }

        // THE ABOUT:BLANK CLOAKING ENGINE
        function cloak(url) {
            const win = window.open('about:blank', '_blank');
            if (win) {
                const doc = win.document;
                doc.title = "Classes"; // Fake title for taskbar
                const iframe = doc.createElement('iframe');
                const style = iframe.style;
                
                style.position = "fixed";
                style.top = style.left = style.bottom = style.right = "0";
                style.width = style.height = "100%";
                style.border = "none";
                
                iframe.src = url;
                doc.body.appendChild(iframe);
                doc.body.style.margin = "0";
                
                activeWins.push(win);
                document.getElementById('dash').style.display = 'none';
            } else {
                alert("POPUP BLOCKED! Allow popups to enable Stealth Mode.");
            }
        }

        function spawnLocalAI() {
            const win = window.open('about:blank', '_blank');
            const doc = win.document;
            doc.title = "System Update";
            doc.body.style.background = "#000";
            doc.body.innerHTML = `
                <div style="color:#f0810f;font-family:monospace;padding:30px;">
                    <h2>REM_AI v71 (AIR-GAPPED)</h2>
                    <div id="l" style="height:70vh;overflow:auto;border:1px solid #222;padding:10px;margin-top:10px;">CORE ACTIVE.</div>
                    <input id="i" style="width:100%;background:#111;color:#fff;border:1px solid #333;padding:15px;margin-top:20px;" placeholder="Input logic stream...">
                </div>
                <script>
                    document.getElementById('i').onkeydown = (e) => {
                        if(e.key === 'Enter') {
                            document.getElementById('l').innerHTML += '<div>> ' + e.target.value + '</div>';
                            setTimeout(()=> { document.getElementById('l').innerHTML += '<div style="color:#fff">REM: Analytical Logic Stable. Cloak Engaged.</div>'; }, 200);
                            e.target.value = "";
                        }
                    }
                <\/script>`;
            activeWins.push(win);
        }

        function panic() {
            activeWins.forEach(w => { if(!w.closed) w.close(); });
            activeWins = [];
            document.getElementById('dash').style.display = 'none';
            document.getElementById('halo').classList.remove('halo-active');
            is2nd = false; cur = "0";
            document.getElementById('display').innerText = "0";
            location.reload();
        }
    </script>
</body>
</html>
