<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>TI-84 Plus 2nd Edition | Total Singularity</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@800&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #2d2d2d; --lcd: #8b9a84; --orange: #f0810f; --red: #d32f2f; --grey: #4a4a4a; }
        body, html { margin: 0; padding: 0; height: 100vh; background: #000; display: flex; justify-content: center; align-items: center; font-family: 'JetBrains Mono', monospace; overflow: hidden; }

        /* CALC UI - AUTHENTIC 2ND EDITION */
        .calc-case { background: var(--bg); border: 2px solid #111; width: 400px; padding: 30px; border-radius: 4px; box-shadow: 10px 10px 0px #1a1a1a; position: relative; z-index: 10; }
        .calc-lcd { background: var(--lcd); border: 4px solid #111; height: 85px; margin-bottom: 25px; padding: 10px; font-size: 2.2rem; text-align: right; color: #1a1a1a; box-shadow: inset 2px 2px 0px rgba(0,0,0,0.2); line-height: 65px; overflow: hidden; }
        .calc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
        .btn { background: var(--grey); color: #fff; border-bottom: 4px solid #1a1a1a; font-size: 1.1rem; font-weight: 800; padding: 15px 0; text-align: center; cursor: pointer; user-select: none; }
        .btn:active { transform: translateY(2px); border-bottom-width: 2px; }
        .orange { background: var(--orange) !important; color: #000 !important; }
        .red { background: var(--red) !important; }
        .led { position: absolute; top: 12px; right: 12px; width: 8px; height: 8px; background: #1a1a1a; transition: 0.2s; }
        .led-on { background: #ff0000; box-shadow: 0 0 5px #ff0000; }

        /* OMNI-OS DASHBOARD */
        #dash { display: none; position: fixed; inset: 0; background: #0a0a0a; z-index: 100; flex-direction: row; color: white; }
        .sidebar { width: 75px; background: #111; border-right: 1px solid #222; display: flex; flex-direction: column; align-items: center; padding: 20px 0; gap: 20px; }
        .side-icon { width: 45px; height: 45px; background: #222; border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 8px; font-weight: 900; cursor: pointer; color: #555; border: 1px solid transparent; }
        .side-icon.active { background: var(--orange); color: #000; border-color: white; }
        
        .main-stage { flex: 1; position: relative; display: flex; flex-direction: column; }
        .app-view { display: none; width: 100%; height: 100%; border: none; }
        .app-view.active { display: block; }

        /* MC / TUFF STYLING */
        .mc-overlay { background: linear-gradient(rgba(0,0,0,0.8), #121212), url('https://minecraft.net/content/dam/minecraftnet/games/minecraft/key-art/MC-Home-Hero-Desktop.jpg'); background-size: cover; height: 100%; padding: 60px; display: flex; flex-direction: column; justify-content: flex-end; }
        #boot-screen { display: none; position: absolute; inset: 0; background: var(--orange); z-index: 200; flex-direction: column; align-items: center; justify-content: center; }

        /* BROWSER BAR */
        .browser-header { background: #1a1a1a; padding: 10px; display: flex; gap: 10px; }
    </style>
</head>
<body onkeydown="if(event.key==='~'){panic()}">

    <div class="calc-case">
        <div class="led" id="led"></div>
        <div class="calc-lcd" id="display">0</div>
        <div class="calc-grid">
            <div class="btn orange" onclick="press('2nd')">2nd</div>
            <div class="btn red" onclick="press('AC')">AC</div>
            <div class="btn red" onclick="press('DEL')">DEL</div>
            <div class="btn" onclick="press('/')">/</div>
            <div class="btn" onclick="press('7')">7</div>
            <div class="btn" onclick="press('8')">8</div>
            <div class="btn" onclick="press('9')">9</div>
            <div class="btn" onclick="press('*')">*</div>
            <div class="btn" onclick="press('4')">4</div>
            <div class="btn" onclick="press('5')">5</div>
            <div class="btn" onclick="press('6')">6</div>
            <div class="btn" onclick="press('-')">-</div>
            <div class="btn" onclick="press('1')">1</div>
            <div class="btn" onclick="press('2')">2</div>
            <div class="btn" onclick="press('3')">3</div>
            <div class="btn" onclick="press('+')">+</div>
            <div class="btn" onclick="press('0')">0</div>
            <div class="btn" onclick="press('.')">.</div>
            <div class="btn orange col-span-2" onclick="press('ENTER')">ENTER</div>
        </div>
    </div>

    <div id="dash">
        <div class="sidebar">
            <div class="side-icon active" onclick="setTab(0, this)"><span>MC</span><span>TUFF</span></div>
            <div class="side-icon" onclick="setTab(1, this)"><span>GIT</span><span>HUB</span></div>
            <div class="side-icon" onclick="setTab(2, this)"><span>BRT</span><span>TATO</span></div>
            <div class="side-icon" onclick="setTab(3, this)"><span>REM</span><span>AI</span></div>
            <div class="side-icon" onclick="setTab(4, this)"><span>WEB</span><span>BROW</span></div>
            <div class="mt-auto text-red-600 font-bold text-[10px] cursor-pointer" onclick="panic()">PANIC</div>
        </div>

        <div class="main-stage">
            <div id="v0" class="app-view active relative">
                <div id="boot-screen">
                    <div class="w-20 h-20 border-8 border-white mb-6"></div>
                    <div id="boot-text" class="text-xs font-black tracking-[0.3em] uppercase">Applying Tuff_Client...</div>
                    <div class="w-64 h-1 bg-white/20 mt-4"><div id="boot-bar" class="bg-white h-full w-0 transition-all duration-75"></div></div>
                </div>
                <div id="mc-ui" class="mc-overlay">
                    <h1 class="text-7xl font-black italic mb-4 tracking-tighter">MINECRAFT</h1>
                    <div class="flex items-center gap-4">
                        <input type="text" id="user" class="bg-black/60 border border-zinc-700 p-4 text-orange-500 font-bold outline-none" value="RemPlayer_1">
                        <button class="bg-white text-black px-12 py-4 font-black text-2xl" onclick="startBoot()">PLAY</button>
                        <button class="bg-zinc-800 px-6 py-4 text-[10px] font-bold" onclick="window.open('https://www.mediafire.com/folder/mzsqrk6tat9wl/tuff_client_stuff')">TUFF_STUFF</button>
                    </div>
                </div>
                <iframe id="mc-frame" class="hidden w-full h-full border-none"></iframe>
            </div>

            <iframe id="v1" class="app-view" src="https://github.com/givvgivv21/LEARNING-WITH-ASIAN-CALCULATOR"></iframe>
            
            <iframe id="v2" class="app-view" src="https://brotato.io/"></iframe>

            <div id="v3" class="app-view bg-[#0d0d0d] p-12">
                <h2 class="text-orange-500 font-black text-3xl mb-4">REM_AI // TERMINAL</h2>
                <textarea class="w-full h-2/3 bg-black border border-zinc-800 p-6 text-orange-400 outline-none font-mono" placeholder="Input command or query..."></textarea>
            </div>

            <div id="v4" class="app-view">
                <div class="browser-header">
                    <input type="text" id="web-url" class="flex-1 bg-black border border-zinc-800 p-2 text-xs text-zinc-400 rounded-full px-5 outline-none" value="https://google.com">
                    <button class="bg-zinc-800 px-4 text-xs font-bold rounded-full" onclick="loadUrl()">GO</button>
                </div>
                <iframe id="web-frame" class="w-full h-full border-none" src="https://google.com"></iframe>
            </div>
        </div>
    </div>

    <script>
        let cur = "0"; let is2nd = false;

        function press(k) {
            if (k === '2nd') { is2nd = !is2nd; document.getElementById('led').classList.toggle('led-on', is2nd); return; }
            if (is2nd && k === 'ENTER') { document.getElementById('dash').style.display = 'flex'; resetShift(); return; }
            if (k === 'AC') panic();
            else if (k === 'ENTER') try { cur = eval(cur.replace('×','*').replace('÷','/')) + ""; } catch { cur = "ERR"; }
            else cur = (cur === "0" ? k : cur + k);
            document.getElementById('display').innerText = cur;
        }

        function startBoot() {
            const boot = document.getElementById('boot-screen');
            const bar = document.getElementById('boot-bar');
            boot.style.display = 'flex';
            let p = 0;
            let int = setInterval(() => {
                p += 2.5;
                bar.style.width = p + '%';
                if (p >= 100) {
                    clearInterval(int);
                    document.getElementById('mc-ui').classList.add('hidden');
                    boot.classList.add('hidden');
                    document.getElementById('mc-frame').classList.remove('hidden');
                    document.getElementById('mc-frame').src = "https://eaglercraft.com/mc/1.8.8/";
                }
            }, 60);
        }

        function setTab(idx, el) {
            document.querySelectorAll('.app-view').forEach((v, i) => v.classList.toggle('active', i === idx));
            document.querySelectorAll('.side-icon').forEach(s => s.classList.remove('active'));
            el.classList.add('active');
        }

        function loadUrl() {
            let url = document.getElementById('web-url').value;
            if(!url.startsWith('http')) url = 'https://' + url;
            document.getElementById('web-frame').src = url;
        }

        function resetShift() { is2nd = false; document.getElementById('led').classList.remove('led-on'); }
        function panic() { location.reload(); }
    </script>
</body>
</html>
