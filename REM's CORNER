<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Rem's Melons :D | v84</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root { --rind: #1a3c1a; --flesh: #ff4d4d; --neon: #39ff14; }
        body, html { 
            margin: 0; padding: 0; height: 100vh; width: 100vw;
            background: #050505; color: white; font-family: 'Courier New', monospace;
            overflow: hidden; 
        }

        /* RAIN ENGINE */
        #rain-container { position: fixed; inset: 0; pointer-events: none; z-index: 1; }
        .melon-drop { position: absolute; font-size: 24px; user-select: none; }

        .ui-wrapper { 
            position: relative; z-index: 10; display: flex; 
            height: 100vh; width: 100vw; background: rgba(0,0,0,0.7);
        }

        .sidebar {
            width: 450px; background: rgba(10, 30, 10, 0.95);
            border-right: 3px solid var(--neon); padding: 40px;
            display: flex; flex-direction: column;
        }

        .ascii-brand {
            font-size: 7px; line-height: 7px; color: var(--neon);
            white-space: pre; margin: 30px 0;
        }

        .melon-btn {
            background: #000; border: 2px solid var(--flesh);
            padding: 18px; margin-bottom: 12px; cursor: pointer;
            font-weight: 900; display: flex; justify-content: space-between;
        }
        .melon-btn:hover { background: var(--flesh); color: #000; transform: scale(1.02); }
        .melon-btn.ai { border-color: var(--neon); color: var(--neon); }

        .main-content {
            flex-grow: 1; display: flex; flex-direction: column;
            align-items: center; justify-content: center; position: relative;
        }

        /* AI TERMINAL TAB */
        #ai-overlay {
            display: none; position: absolute; width: 80%; height: 60%;
            background: #000; border: 2px solid var(--neon);
            padding: 30px; box-shadow: 0 0 50px rgba(0,255,65,0.2);
            flex-direction: column;
        }
    </style>
</head>
<body onkeydown="if(event.key==='Escape') panic()">

    <div id="rain-container"></div>

    <div class="ui-wrapper">
        <div class="sidebar">
            <h1 class="text-3xl font-black italic">REM'S MELONS :D</h1>
            
<div class="ascii-brand">
++++++   +++++++  ++      ++   +++++++  
++   ++  ++       +++    +++  ++        
++   ++  +++++    ++ +  + ++  +++++++   
++++++   ++       ++  ++  ++        ++  
++  ++   ++       ++      ++        ++  
++   ++  +++++++  ++      ++   +++++++  

+++++++   ++++++   +++++++   ++   ++  +++++++  ++++++  
++       ++    ++  ++    ++  +++  ++  ++       ++   ++ 
++       ++    ++  +++++++   ++ + ++  +++++    ++++++  
++       ++    ++  ++  ++    ++  +++  ++       ++  ++  
+++++++   ++++++   ++   ++   ++   ++  +++++++  ++   ++
</div>

            <div class="nav-group">
                <div class="melon-btn" onclick="melonInject('https://eaglercraft.q13x.com/')">
                    <span>GHOST MINECRAFT</span><span>🍉</span>
                </div>
                <div class="melon-btn" onclick="melonInject('https://www.google.com/search?igu=1')">
                    <span>STEALTH GOOGLE</span><span>🍉</span>
                </div>
                <div class="melon-btn ai" onclick="toggleAI()">
                    <span>OPEN MELON_AI</span><span>[🤖]</span>
                </div>
            </div>

            <div class="mt-auto melon-btn" style="border-color:white; color:white" onclick="panic()">
                <span>PURGE SESSIONS</span><span>[ESC]</span>
            </div>
        </div>

        <div class="main-content">
            <div id="hero">
                <div class="text-8xl mb-4 text-center">🍉</div>
                <div class="text-5xl font-black text-red-500 italic">MELON_v84</div>
            </div>

            <div id="ai-overlay">
                <div class="flex justify-between items-center mb-4 border-bottom border-green-500">
                    <span class="text-green-500 font-bold">MELON_AI_CORE v1.0</span>
                    <button onclick="toggleAI()" class="text-red-500">[CLOSE]</button>
                </div>
                <div id="ai-log" class="overflow-y-auto flex-grow text-green-400 text-sm">
                    > Melon-Seed AI Online...<br>
                    > Tracking Eaglercraft login status... [OK]<br>
                    > Bypass Protocol: Data-Injection... [READY]<br>
                    > How can I assist your melon session today?<br>
                </div>
                <input type="text" id="ai-input" class="bg-transparent border-t border-green-900 p-2 mt-4 outline-none text-green-500" placeholder="Ask Melon AI...">
            </div>
        </div>
    </div>

    <script>
        // RAIN ENGINE
        function createMelon() {
            const container = document.getElementById('rain-container');
            const melon = document.createElement('div');
            melon.className = 'melon-drop'; melon.innerText = '🍉';
            melon.style.left = Math.random() * 100 + 'vw';
            melon.style.top = '-50px';
            const duration = Math.random() * 3 + 2;
            melon.style.transition = `top ${duration}s linear`;
            container.appendChild(melon);
            setTimeout(() => { melon.style.top = '110vh'; }, 10);
            setTimeout(() => melon.remove(), duration * 1000);
        }
        setInterval(createMelon, 300);

        let activeWindows = [];

        // v84 INJECTION ENGINE (Fixes "Refused to Connect")
        function melonInject(url) {
            const win = window.open('about:blank', '_blank', `width=1200,height=800,popup=yes`);
            if (!win) return alert("Enable Popups!");

            // Instead of an iframe, we inject a script that redirects the window
            // This stops the site from thinking it's being "framed"
            win.document.write(`
                <body style="background:#000;display:flex;align-items:center;justify-content:center;height:100vh;margin:0;font-family:sans-serif;">
                    <div style="text-align:center;">
                        <div style="font-size:50px;">🍉</div>
                        <h2 style="color:#39ff14;">Injecting Melon-Link...</h2>
                    </div>
                    <script>
                        setTimeout(() => { window.location.href = "${url}"; }, 300);
                    <\/script>
                </body>
            `);
            activeWindows.push(win);
        }

        function toggleAI() {
            const ai = document.getElementById('ai-overlay');
            const hero = document.getElementById('hero');
            if (ai.style.display === 'flex') {
                ai.style.display = 'none';
                hero.style.opacity = '1';
            } else {
                ai.style.display = 'flex';
                hero.style.opacity = '0.1';
            }
        }

        function panic() {
            activeWindows.forEach(w => { if(!w.closed) w.close(); });
            activeWindows = [];
            location.reload();
        }
    </script>
</body>
</html>
