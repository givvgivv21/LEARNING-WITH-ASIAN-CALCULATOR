<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rem's Corner | Engine-Grade v14</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/skinview3d@3.0.0/dist/skinview3d.bundle.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <style>
        :root { --red: #dc2626; --orange: #f97316; --mc-gray: #313335; }
        body { background: radial-gradient(circle at top left, #450a0a 0%, #09090b 100%); color: #fff; font-family: 'Plus Jakarta Sans', sans-serif; height: 100vh; overflow: hidden; margin: 0; }
        
        /* AUTHENTIC MC LAUNCHER */
        .mc-container { background: var(--mc-gray); width: 100%; height: 580px; border-radius: 5px; display: flex; flex-direction: column; overflow: hidden; border: 1px solid #111; }
        .mc-top-nav { background: #2b2b2b; height: 40px; display: flex; align-items: center; padding: 0 15px; gap: 20px; border-bottom: 1px solid #1a1a1a; }
        .mc-tab { font-size: 11px; color: #aaa; cursor: pointer; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
        .mc-tab.active { color: #fff; border-bottom: 2px solid #fff; padding-bottom: 11px; margin-bottom: -13px; }
        
        .mc-sidebar { width: 200px; background: #1e1e1e; padding: 15px 5px; }
        .mc-side-item { padding: 10px 15px; font-size: 13px; color: #bbb; cursor: pointer; border-radius: 4px; margin-bottom: 2px; }
        .mc-side-item.active { background: #4e4e4e; color: #fff; font-weight: bold; }
        
        .mc-main { flex: 1; background: url('https://minecraft.net/content/dam/minecraftnet/games/minecraft/key-art/MC-Home-Hero-Desktop.jpg') center/cover; position: relative; }
        .mc-footer { position: absolute; bottom: 0; width: 100%; height: 85px; background: rgba(0,0,0,0.85); display: flex; align-items: center; justify-content: space-between; padding: 0 25px; border-top: 1px solid #444; }
        
        .play-btn { background: #3c8527; color: white; padding: 12px 55px; font-size: 22px; font-weight: 900; border-radius: 2px; border-bottom: 4px solid #2a5d1b; cursor: pointer; }
        .play-btn:hover { background: #47a02e; }

        /* MOD BUTTON UPGRADE */
        .forge-badge { background: linear-gradient(45deg, #f97316, #dc2626); padding: 4px 12px; border-radius: 4px; font-size: 10px; font-weight: 900; color: white; box-shadow: 0 0 15px rgba(249, 115, 22, 0.4); border: 1px solid rgba(255,255,255,0.2); }

        /* STEALH CALCULATOR */
        .widget { background: rgba(20, 20, 25, 0.98); padding: 2rem; border-radius: 50px; border: 1px solid rgba(220, 38, 38, 0.3); }
        .screen { background: #000; border-radius: 25px; padding: 1rem; text-align: right; font-family: 'JetBrains Mono'; color: var(--orange); font-size: 2.2rem; border: 1px solid var(--red); margin-bottom: 1rem; }
        .key { height: 50px; border-radius: 25px; background: rgba(255,255,255,0.03); font-weight: 800; cursor: pointer; color: #fecaca; }
        .key:hover { background: var(--red); color: white; }

        #rem-os { position: fixed; inset: 0; background: #0a0a0c; z-index: 5000; display: none; flex-direction: column; border-top: 4px solid var(--red); }
        #skin-viewer-container { width: 300px; height: 400px; background: rgba(0,0,0,0.6); border: 2px solid #444; border-radius: 10px; margin-bottom: 20px; }
    </style>
</head>
<body>

    <nav class="p-6 px-12 flex justify-between items-center border-b border-red-900/30">
        <div class="font-black text-2xl tracking-tighter text-white">REMS<span class="text-orange-500">CORNER</span></div>
        <button onclick="downloadSelf()" class="bg-red-600 text-white px-6 py-2 rounded-full font-bold text-[10px] uppercase">Export KERNEL v14</button>
    </nav>

    <div class="grid grid-cols-[1fr_380px] gap-8 p-12 h-[calc(100vh-100px)]">
        <div class="space-y-6">
            <div class="bg-red-950/10 border border-red-500/20 p-10 rounded-[50px] backdrop-blur-md">
                <h1 class="text-5xl font-black mb-4 italic text-white uppercase tracking-tighter">Potato <span class="text-orange-500">Engine</span></h1>
                <p class="text-red-100/60 leading-relaxed text-lg">Brotato Core fully reconstructed. Minecraft Launcher 1:1 GUI active. Press [P] in-game to toggle MODS.</p>
            </div>
        </div>

        <div class="widget">
            <div class="screen" id="calc-val">0</div>
            <div class="grid grid-cols-4 gap-2">
                <button id="btn-2nd" class="key" onclick="toggle2nd()">2nd</button>
                <button class="key" onclick="deleteChar()">DEL</button>
                <button class="key" onclick="handleClear()">AC</button>
                <button class="key text-orange-500" onclick="handleTuff()">÷</button>
                <button class="key" onclick="append('7')">7</button>
                <button class="key" onclick="append('8')">8</button>
                <button class="key" onclick="append('9')">9</button>
                <button class="key text-orange-500" onclick="append('*')">×</button>
                <button class="key" onclick="append('4')">4</button>
                <button class="key" onclick="append('5')">5</button>
                <button class="key" onclick="append('6')">6</button>
                <button class="key text-orange-500" onclick="append('-')">-</button>
                <button class="key" onclick="append('1')">1</button>
                <button class="key" onclick="append('2')">2</button>
                <button class="key" onclick="append('3')">3</button>
                <button class="key text-orange-500" onclick="append('+')">+</button>
                <button class="key col-span-2" onclick="append('0')">0</button>
                <button class="key" onclick="append('.')">.</button>
                <button class="key bg-gradient-to-br from-red-600 to-orange-600 text-white border-none" onclick="handleEnter()">=</button>
            </div>
        </div>
    </div>

    <div id="rem-os">
        <div class="flex flex-1">
            <div class="w-64 bg-black p-8 border-r border-red-900/30 flex flex-col gap-2">
                <button onclick="showTab('mc')" class="text-left p-4 rounded-xl hover:bg-red-900/20 font-bold transition">🎮 Minecraft</button>
                <button onclick="showTab('bt')" class="text-left p-4 rounded-xl hover:bg-orange-900/20 font-bold transition text-orange-500">🥔 Brotato Arena</button>
                <button onclick="showTab('ai')" class="text-left p-4 rounded-xl hover:bg-red-900/20 font-bold transition">🤖 Rem AI</button>
                <button onclick="closeOS()" class="mt-auto text-red-500 font-black text-[10px] text-center p-4 hover:text-white transition uppercase">[Close Session]</button>
            </div>

            <div class="flex-1 p-10 bg-[#0c0c0e] overflow-y-auto">
                
                <div id="tab-mc" class="os-tab">
                    <div class="mc-container">
                        <div class="mc-top-nav">
                            <div class="mc-tab active">Java Edition</div>
                            <div class="mc-tab">Installations</div>
                            <div class="mc-tab">Skins</div>
                            <div class="mc-tab">Patch Notes</div>
                        </div>
                        <div class="flex flex-1 overflow-hidden">
                            <div class="mc-sidebar">
                                <div class="mc-side-item active" onclick="switchMC('play')">Play</div>
                                <div class="mc-side-item" onclick="switchMC('skins')">Skins</div>
                            </div>
                            <div class="mc-main">
                                <div id="mc-view-skins" class="hidden absolute inset-0 bg-[#2b2b2b] p-8 flex flex-col items-center">
                                    <div id="skin-viewer-container"></div>
                                    <div class="flex gap-4">
                                        <button onclick="document.getElementById('skin-upload').click()" class="bg-white text-black px-8 py-2 font-black text-xs rounded uppercase">Select PNG</button>
                                        <input type="file" id="skin-upload" class="hidden" onchange="loadSkin(this)">
                                    </div>
                                    <p class="text-[10px] text-gray-500 mt-4">REAL-TIME 3D RENDER PREVIEW</p>
                                </div>
                                <div class="mc-footer">
                                    <div class="flex items-center gap-3">
                                        <div class="forge-badge">MODS ENABLED</div>
                                        <div class="text-xs font-bold text-white">Latest Forge 1.12.2</div>
                                    </div>
                                    <button class="play-btn" onclick="launchGame('mc')">PLAY</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="tab-bt" class="os-tab hidden">
                    <div class="bg-[#1a1a1a] p-10 rounded-2xl border-2 border-orange-600 h-full flex flex-col items-center justify-center text-center">
                        <h2 class="text-5xl font-black text-orange-500 mb-4 italic">BROTATO <span class="text-white">CORE</span></h2>
                        <p class="text-gray-400 mb-8 max-w-md">Full engine reconstruction. Optimized for high-FPS browser play with direct input fix.</p>
                        <button class="bg-orange-600 hover:bg-orange-500 text-white font-black text-3xl px-20 py-6 rounded-xl shadow-2xl transition" onclick="launchGame('bt')">ENTER ARENA</button>
                    </div>
                </div>

                <div id="tab-ai" class="os-tab hidden">
                    <div id="ai-chat" class="h-[400px] bg-black/80 rounded-3xl border border-red-500/20 p-8 overflow-y-auto mb-4 font-mono text-xs"></div>
                    <div class="flex gap-4">
                        <input type="text" id="ai-input" class="flex-1 bg-white/5 border border-white/10 rounded-full px-8 py-4 outline-none" placeholder="Execute command...">
                        <button onclick="sendAI()" class="bg-red-600 px-10 rounded-full font-black text-xs uppercase">Run</button>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        let is2nd = false; let input = "0"; let skinViewer;
        
        window.onload = () => {
            skinViewer = new skinview3d.SkinViewer({ canvas: document.getElementById("skin-viewer-container"), width: 300, height: 400, skin: "https://minotar.net/skin/char" });
            skinViewer.autoRotate = true; skinViewer.animation = new skinview3d.WalkingAnimation();
        };

        function launchGame(type) {
            const url = type === 'mc' ? 'https://takaiwebsite.neocities.org/minecraft' : 'https://blobby-boi.github.io/brotato/';
            const win = window.open("about:blank", "_blank");
            win.document.write(`
                <html><head><title>System.IO.Core</title><style>
                    body,html{margin:0;padding:0;height:100%;background:#000;overflow:hidden;font-family:sans-serif;}
                    #mod-menu { display:none; position:fixed; top:20px; right:20px; width:220px; background:rgba(20,20,20,0.95); border:2px solid #dc2626; color:white; padding:15px; border-radius:10px; z-index:9999; box-shadow:0 0 30px rgba(220,38,38,0.5);}
                    .mod-item { display:flex; justify-content:space-between; font-size:11px; margin-bottom:10px; font-weight:bold; color:#ff9999;}
                </style></head>
                <body>
                    <div id="mod-menu">
                        <h3 style="margin:0 0 15px 0; color:#f97316; font-size:14px; text-transform:uppercase;">Forge Redline Mod</h3>
                        <div class="mod-item"><span>AUTO-CLICKER</span> <span style="color:#00ff00;">ON</span></div>
                        <div class="mod-item"><span>X-RAY VISION</span> <span style="color:#00ff00;">ON</span></div>
                        <div class="mod-item"><span>SPEED HACK</span> <span style="color:#777;">OFF</span></div>
                        <hr style="border:0; border-top:1px solid #444; margin:10px 0;">
                        <div style="font-size:9px; color:#aaa;">PRESS [P] TO TOGGLE THIS MENU</div>
                    </div>
                    <iframe id="f" src="${url}" style="width:100vw;height:100vh;border:none;" allow="autoplay; fullscreen; gamepad; pointer-lock" sandbox="allow-forms allow-modals allow-pointer-lock allow-popups allow-same-origin allow-scripts"></iframe>
                    <script>
                        const frame = document.getElementById('f');
                        window.onload = () => { frame.focus(); };
                        window.addEventListener('keydown', (e) => {
                            if(e.key.toLowerCase() === 'p') {
                                const m = document.getElementById('mod-menu');
                                m.style.display = m.style.display === 'block' ? 'none' : 'block';
                            }
                        });
                    <\/script>
                </body></html>
            `);
        }

        function switchMC(view) {
            document.getElementById('mc-view-skins').classList.toggle('hidden', view !== 'skins');
            document.querySelectorAll('.mc-side-item').forEach(i => i.classList.remove('active'));
            event.currentTarget.classList.add('active');
        }

        function loadSkin(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = (e) => { skinViewer.loadSkin(e.target.result); };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function sendAI() {
            const i = document.getElementById('ai-input'); const c = document.getElementById('ai-chat'); if(!i.value) return;
            c.innerHTML += `<div class="mb-2 text-white font-bold">USER: ${i.value}</div>`;
            setTimeout(() => { c.innerHTML += `<div class="mb-4 text-orange-400">REM: Engine v14 online. Mod menu bound to "P" key. Skin preview engine active. Brotato core stable.</div>`; c.scrollTop = c.scrollHeight; }, 400);
            i.value = '';
        }

        function downloadSelf() { const b = new Blob([document.documentElement.outerHTML], {type: "text/html"}); const a = document.createElement("a"); a.href = URL.createObjectURL(b); a.download = "Rems_Corner_v14.html"; a.click(); }
        function toggle2nd() { is2nd = !is2nd; document.getElementById('btn-2nd').classList.toggle('key-active', is2nd); }
        function append(v) { input = input === "0" ? v : input + v; document.getElementById('calc-val').innerText = input; }
        function deleteChar() { input = input.slice(0, -1) || "0"; document.getElementById('calc-val').innerText = input; }
        function handleClear() { input = "0"; document.getElementById('calc-val').innerText = "0"; }
        function handleTuff() { if(is2nd) { openOS(); showTab('mc'); toggle2nd(); } else append('/'); }
        function handleEnter() { if(is2nd) { openOS(); toggle2nd(); } else { try { input = String(eval(input.replace('×','*').replace('÷','/'))); document.getElementById('calc-val').innerText = input; } catch { document.getElementById('calc-val').innerText = "Error"; } } }
        function openOS() { document.getElementById('rem-os').style.display = 'flex'; }
        function closeOS() { document.getElementById('rem-os').style.display = 'none'; }
        function showTab(t) { document.querySelectorAll('.os-tab').forEach(x => x.classList.add('hidden')); document.getElementById('tab-'+t).classList.remove('hidden'); }
    </script>
</body>
</html>
