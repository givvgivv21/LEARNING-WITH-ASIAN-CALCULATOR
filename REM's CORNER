<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>TI-84 Plus 2nd Edition | Omni-OS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@800&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #2d2d2d; --lcd: #8b9a84; --orange: #f0810f; --red: #d32f2f; --grey: #4a4a4a; }
        body, html { margin: 0; padding: 0; height: 100vh; background: #000; display: flex; justify-content: center; align-items: center; font-family: 'JetBrains Mono', monospace; overflow: hidden; }

        /* CALC UI */
        .calc-case { background: var(--bg); border: 2px solid #111; width: 400px; padding: 30px; border-radius: 4px; box-shadow: 10px 10px 0px #1a1a1a; position: relative; z-index: 10; }
        .calc-lcd { background: var(--lcd); border: 4px solid #111; height: 85px; margin-bottom: 25px; padding: 10px; font-size: 2.2rem; text-align: right; color: #1a1a1a; box-shadow: inset 2px 2px 0px rgba(0,0,0,0.2); line-height: 65px; }
        .calc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
        .btn { background: var(--grey); color: #fff; border-bottom: 4px solid #1a1a1a; font-size: 1.1rem; font-weight: 800; padding: 15px 0; text-align: center; cursor: pointer; user-select: none; }
        .btn:active { transform: translateY(2px); border-bottom-width: 2px; }
        .orange { background: var(--orange) !important; color: #000 !important; }
        .red { background: var(--red) !important; }

        /* MASTER DASHBOARD */
        #dash { display: none; position: fixed; inset: 0; background: #0a0a0a; z-index: 100; flex-direction: row; color: white; }
        
        /* SIDEBAR */
        .sidebar { width: 70px; background: #111; border-right: 1px solid #222; display: flex; flex-direction: column; align-items: center; padding: 20px 0; gap: 20px; }
        .side-icon { width: 40px; height: 40px; background: #222; border-radius: 8px; display: flex; items: center; justify-content: center; font-size: 10px; font-weight: 900; cursor: pointer; transition: 0.2s; border: 1px solid transparent; color: #555; }
        .side-icon.active { background: var(--orange); color: #000; border-color: white; }
        .side-icon:hover { color: white; border-color: #444; }

        /* MAIN VIEW */
        .main-stage { flex: 1; display: flex; flex-direction: column; }
        .view-frame { flex: 1; width: 100%; height: 100%; border: none; display: none; }
        .view-frame.active { display: block; }

        /* SPECIAL MC VIEW */
        #p-mc { background: #121212; }
        .mc-overlay { background: linear-gradient(rgba(0,0,0,0.7), #121212), url('https://minecraft.net/content/dam/minecraftnet/games/minecraft/key-art/MC-Home-Hero-Desktop.jpg'); background-size: cover; height: 100%; padding: 60px; display: flex; flex-direction: column; justify-content: flex-end; }

        /* BOOT SCREEN */
        #boot-screen { display: none; position: absolute; inset: 0; background: var(--orange); z-index: 200; flex-direction: column; align-items: center; justify-content: center; }
        .progress-bar { width: 0%; height: 100%; background: white; }

        .browser-bar { background: #1a1a1a; padding: 10px; display: flex; gap: 10px; border-bottom: 1px solid #333; }
        .browser-input { background: #000; border: 1px solid #333; color: #888; padding: 5px 15px; flex: 1; border-radius: 20px; font-size: 11px; outline: none; }
    </style>
</head>
<body onkeydown="if(event.key==='~'){panic()}">

    <div class="calc-case">
        <div id="display" class="calc-lcd">0</div>
        <div class="calc-grid">
            <div class="btn orange" onclick="press('2nd')">2nd</div>
            <div class="btn red" onclick="press('AC')">AC</div>
            <div class="btn red" onclick="press('DEL')">DEL</div>
            <div class="btn" onclick="press('/')">/</div>
            <div class="btn" onclick="press('7')">7</div>
            <div class="btn" onclick="press('8')">8</div>
            <div class="btn" onclick="press('9')">9</div>
            <div class="btn" onclick="press('*')">*</div>
            <div class="btn" onclick="press('4')">4</div>
            <div class="btn" onclick="press('5')">5</div>
            <div class="btn" onclick="press('6')">6</div>
            <div class="btn" onclick="press('-')">-</div>
            <div class="btn" onclick="press('1')">1</div>
            <div class="btn" onclick="press('2')">2</div>
            <div class="btn" onclick="press('3')">3</div>
            <div class="btn" onclick="press('+')">+</div>
            <div class="btn" onclick="press('0')">0</div>
            <div class="btn" onclick="press('.')">.</div>
            <div class="btn orange col-span-2" onclick="press('ENTER')">ENTER</div>
        </div>
    </div>

    <div id="dash">
        <div class="sidebar">
            <div class="side-icon active" onclick="setTab(0, this)">MC</div>
            <div class="side-icon" onclick="setTab(1, this)">GIT</div>
            <div class="side-icon" onclick="setTab(2, this)">BRT</div>
            <div class="side-icon" onclick="setTab(3, this)">AI</div>
            <div class="side-icon" onclick="setTab(4, this)">WEB</div>
            <div class="mt-auto text-red-600 font-bold text-[10px] cursor-pointer" onclick="panic()">PANIC</div>
        </div>

        <div class="main-stage">
            <div id="p-mc" class="view-frame active relative">
                <div id="boot-screen">
                    <div class="w-16 h-16 border-4 border-white mb-6"></div>
                    <div id="boot-text" class="text-xs font-bold tracking-widest uppercase">Initializing Tuff_Client...</div>
                    <div class="w-48 h-1 bg-white/20 mt-4"><div id="boot-bar" class="progress-bar h-full"></div></div>
                </div>
                <div id="mc-launcher" class="mc-overlay">
                    <h1 class="text-6xl font-black italic mb-4 tracking-tighter">MINECRAFT</h1>
                    <div class="flex gap-4">
                        <button class="bg-white text-black px-12 py-3 font-black text-xl" onclick="startBoot()">PLAY</button>
                        <button class="bg-zinc-800 px-6 py-3 text-[10px] font-bold" onclick="window.open('https://www.mediafire.com/folder/mzsqrk6tat9wl/tuff_client_stuff')">TUFF_STUFF</button>
                    </div>
                </div>
                <iframe id="mc-game" class="hidden w-full h-full border-none"></iframe>
            </div>

            <iframe id="p-git" class="view-frame" src="https://github.com/givvgivv21/LEARNING-WITH-ASIAN-CALCULATOR"></iframe>
            
            <iframe id="p-brt" class="view-frame" src="https://brotato.io/"></iframe>

            <div id="p-ai" class="view-frame bg-[#121212] p-10">
                <div class="max-w-2xl">
                    <h2 class="text-orange-500 font-black text-2xl mb-2">REM_AI // CORE</h2>
                    <p class="text-zinc-500 text-xs mb-8">Integrated Assistant Protocol active.</p>
                    <input type="text" class="w-full bg-black border border-zinc-800 p-4 text-orange-500 outline-none" placeholder="Enter inquiry...">
                </div>
            </div>

            <div id="p-web" class="view-frame">
                <div class="browser-bar">
                    <input type="text" class="browser-input" id="web-url" value="https://www.google.com/search?q=calculator" onkeydown="if(event.key==='Enter') loadUrl()">
                </div>
                <iframe id="web-frame" class="w-full h-full border-none" src="https://www.google.com/search?q=calculator"></iframe>
            </div>
        </div>
    </div>

    <script>
        let cur = "0"; let is2nd = false;

        function press(k) {
            if (k === '2nd') { is2nd = !is2nd; return; }
            if (is2nd && k === 'ENTER') { document.getElementById('dash').style.display = 'flex'; is2nd = false; return; }
            if (k === 'AC') panic();
            else if (k === 'ENTER') try { cur = eval(cur.replace('×','*').replace('÷','/')) + ""; } catch { cur = "ERR"; }
            else cur = (cur === "0" ? k : cur + k);
            document.getElementById('display').innerText = cur;
        }

        function setTab(idx, el) {
            document.querySelectorAll('.view-frame').forEach((f, i) => f.classList.toggle('active', i === idx));
            document.querySelectorAll('.side-icon').forEach(s => s.classList.remove('active'));
            el.classList.add('active');
        }

        function loadUrl() {
            let url = document.getElementById('web-url').value;
            if(!url.startsWith('http')) url = 'https://' + url;
            document.getElementById('web-frame').src = url;
        }

        function startBoot() {
            const boot = document.getElementById('boot-screen');
            const bar = document.getElementById('boot-bar');
            boot.style.display = 'flex';
            let p = 0;
            let int = setInterval(() => {
                p += 2;
                bar.style.width = p + '%';
                if (p >= 100) {
                    clearInterval(int);
                    document.getElementById('mc-launcher').classList.add('hidden');
                    boot.classList.add('hidden');
                    document.getElementById('mc-game').classList.remove('hidden');
                    document.getElementById('mc-game').src = "https://takaiwebsite.neocities.org/minecraft";
                }
            }, 30);
        }

        function panic() { location.reload(); }
    </script>
</body>
</html>
