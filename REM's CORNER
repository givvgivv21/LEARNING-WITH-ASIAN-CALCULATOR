<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Rem's Melons :D | v83 PATCH</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root { --rind: #1a3c1a; --flesh: #ff4d4d; --neon: #39ff14; }
        body, html { 
            margin: 0; padding: 0; height: 100vh; width: 100vw;
            background: #050505; color: white; font-family: 'Courier New', monospace;
            overflow: hidden; 
        }

        /* MELON RAIN */
        #rain-container { position: fixed; inset: 0; pointer-events: none; z-index: 1; }
        .melon-drop { position: absolute; font-size: 24px; user-select: none; }

        .ui-wrapper { 
            position: relative; z-index: 10; display: flex; 
            height: 100vh; width: 100vw; background: rgba(0,0,0,0.7);
        }

        .sidebar {
            width: 450px; background: rgba(10, 30, 10, 0.95);
            border-right: 3px solid var(--neon); padding: 40px;
            display: flex; flex-direction: column;
        }

        .ascii-brand {
            font-size: 7px; line-height: 7px; color: var(--neon);
            white-space: pre; margin: 30px 0;
        }

        .melon-btn {
            background: #000; border: 2px solid var(--flesh);
            padding: 20px; margin-bottom: 15px; cursor: pointer;
            font-weight: 900; display: flex; justify-content: space-between;
        }
        .melon-btn:hover { background: var(--flesh); color: #000; }

        .main-content {
            flex-grow: 1; display: flex; flex-direction: column;
            align-items: center; justify-content: center;
        }
    </style>
</head>
<body onkeydown="if(event.key==='Escape') panic()">

    <div id="rain-container"></div>

    <div class="ui-wrapper">
        <div class="sidebar">
            <h1 class="text-3xl font-black italic">REM'S MELONS :D</h1>
            
<div class="ascii-brand">
++++++   +++++++  ++      ++   +++++++  
++   ++  ++       +++    +++  ++        
++   ++  +++++    ++ +  + ++  +++++++   
++++++   ++       ++  ++  ++        ++  
++  ++   ++       ++      ++        ++  
++   ++  +++++++  ++      ++   +++++++  

+++++++   ++++++   +++++++   ++   ++  +++++++  ++++++  
++       ++    ++  ++    ++  +++  ++  ++       ++   ++ 
++       ++    ++  +++++++   ++ + ++  +++++    ++++++  
++       ++    ++  ++  ++    ++  +++  ++       ++  ++  
+++++++   ++++++   ++   ++   ++   ++  +++++++  ++   ++
</div>

            <div class="nav-group">
                <div class="melon-btn" onclick="melonNavigate('https://eaglercraft.q13x.com/', 'Eaglercraft')">
                    <span>MINECRAFT (PROXY)</span><span>🍉</span>
                </div>
                <div class="melon-btn" onclick="melonNavigate('https://www.google.com/search?igu=1', 'Research')">
                    <span>STEALTH GOOGLE</span><span>🍉</span>
                </div>
                <div class="melon-btn" onclick="melonNavigate('https://duckduckgo.com', 'Search')">
                    <span>DUCKDUCKGO (NO-BLOCK)</span><span>🍉</span>
                </div>
            </div>

            <div class="mt-auto melon-btn" style="border-color:white; color:white" onclick="panic()">
                <span>WIPE ALL</span><span>[ESC]</span>
            </div>
        </div>

        <div class="main-content">
            <div class="text-6xl font-black text-red-500 italic mb-4">MELON_v83</div>
            <p class="text-green-400 font-bold">BYPASSING "REFUSED TO CONNECT" ERROR...</p>
        </div>
    </div>

    <script>
        // RAIN SCRIPT
        function createMelon() {
            const container = document.getElementById('rain-container');
            const melon = document.createElement('div');
            melon.className = 'melon-drop';
            melon.innerText = '🍉';
            melon.style.left = Math.random() * 100 + 'vw';
            melon.style.top = '-50px';
            const duration = Math.random() * 3 + 2;
            melon.style.transition = `top ${duration}s linear`;
            container.appendChild(melon);
            setTimeout(() => { melon.style.top = '110vh'; }, 10);
            setTimeout(() => melon.remove(), duration * 1000);
        }
        setInterval(createMelon, 300);

        let activeWindows = [];

        // v83 NAVIGATION ENGINE (ANTI-REFUSAL)
        function melonNavigate(url, title) {
            const w = 1200;
            const h = 800;
            const left = (window.screen.width / 2) - (w / 2);
            const top = (window.screen.height / 2) - (h / 2);

            // Open a true separate window
            const win = window.open('about:blank', '_blank', `width=${w},height=${h},top=${top},left=${left},popup=yes`);

            if (!win) {
                alert("Allow popups first!");
                return;
            }

            /* CRITICAL FIX: Instead of an iframe (which big sites block), 
               we write a script to the window that forces it to navigate 
               while staying in its own process. 
            */
            win.document.write(`
                <html>
                <head><title>${title}</title></head>
                <body style="background:#000; display:flex; align-items:center; justify-content:center; height:100vh;">
                    <h1 style="color:#39ff14; font-family:monospace;">🍉 Loading Melon-Link...</h1>
                    <script>
                        setTimeout(() => {
                            window.location.replace("${url}");
                        }, 500);
                    <\/script>
                </body>
                </html>
            `);

            activeWindows.push(win);
        }

        function panic() {
            activeWindows.forEach(w => { if(!w.closed) w.close(); });
            activeWindows = [];
            location.reload();
        }
    </script>
</body>
</html>
