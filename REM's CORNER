<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Khan Academy | Progress Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <style>
        :root { --mc-sidebar: #1e1e1e; --mc-bg: #2b2b2b; --mc-green: #3c8527; --ti-orange: #ff922b; --ti-red: #e03131; }
        body { background: #f7f9fb; font-family: 'Plus Jakarta Sans', sans-serif; margin: 0; overflow: hidden; height: 100vh; }
        
        #rem-os { position: fixed; inset: 0; background: #010409; z-index: 9999; display: none; padding: 20px; grid-template-columns: 280px 1fr; gap: 20px; }
        .os-sidebar { background: #0d1117; border: 4px solid #30363d; border-radius: 12px; padding: 15px; display: flex; flex-direction: column; gap: 10px; }
        .os-tab { display: none; height: 100%; }
        .active-tab { display: flex !important; }

        /* OFFICIAL MINECRAFT LAUNCHER GUI */
        .mc-window { background: var(--mc-bg); border-radius: 12px; flex: 1; display: flex; overflow: hidden; border: 1px solid #444; }
        .mc-left-nav { width: 70px; background: #181818; display: flex; flex-direction: column; align-items: center; padding-top: 20px; gap: 15px; border-right: 1px solid #333; }
        .mc-game-icon { width: 45px; height: 45px; border-radius: 6px; cursor: pointer; border: 2px solid transparent; background-size: cover; background-position: center; }
        .mc-game-icon.active { border-color: #fff; background-color: #333; }
        
        .mc-content { flex: 1; display: flex; flex-direction: column; background: #1a1a1a; }
        .mc-header { height: 45px; background: #212121; display: flex; align-items: center; padding-left: 25px; gap: 20px; font-size: 11px; font-weight: 800; color: #999; border-bottom: 1px solid #333; }
        .mc-header span:hover { color: #fff; cursor: pointer; }
        .mc-header .active { color: #fff; border-bottom: 2px solid #fff; padding-bottom: 2px; }

        .mc-hero { height: 280px; background: linear-gradient(to bottom, transparent, #1a1a1a), url('https://minecraft.net/content/dam/minecraftnet/games/minecraft/key-art/MC-Home-Hero-Desktop.jpg'); background-size: cover; padding: 30px; display: flex; flex-direction: column; justify-content: flex-end; }
        .mc-play-bar { height: 90px; background: #1e1e1e; margin-top: auto; display: flex; align-items: center; justify-content: center; border-top: 1px solid #333; gap: 20px; }
        .mc-play-btn { background: var(--mc-green); color: white; width: 200px; height: 50px; border-radius: 4px; font-size: 22px; font-weight: 900; box-shadow: 0 4px 0 #2a5d1b; display: flex; align-items: center; justify-content: center; cursor: pointer; }

        /* OG TI-84 CALCULATOR GUI */
        .ti-case { background: #343a40; border-radius: 25px; padding: 25px; border: 5px solid #1a1a1a; width: 380px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .ti-lcd { background: #94a891; border: 10px solid #1a1a1a; border-radius: 4px; height: 100px; padding: 15px; font-family: 'JetBrains Mono'; font-size: 2.5rem; text-align: right; color: #1a1a1a; margin-bottom: 25px; box-shadow: inset 2px 2px 5px rgba(0,0,0,0.3); }
        .ti-key { background: #495057; color: white; border-radius: 8px; border-bottom: 4px solid #212529; font-weight: 800; padding: 15px; font-size: 1.1rem; text-align: center; }
        .ti-key:active { transform: translateY(2px); border-bottom-width: 2px; }
        .key-orange { background: var(--ti-orange) !important; color: #000; }
        .key-red { background: var(--ti-red) !important; }

        .btn-bulky { background: #21262d; border: 3px solid #484f58; color: white; font-weight: 800; padding: 15px; border-radius: 8px; text-align: left; }
        .active-side { border-color: var(--ti-orange); color: var(--ti-orange); }
    </style>
</head>
<body onkeydown="if(event.key==='~'){panic()}">

    <div id="edu-layer" class="h-full flex flex-col">
        <nav class="flex items-center justify-between px-10 h-[70px] bg-white border-b">
            <div class="text-2xl font-black text-[#14316d]">KHAN<span class="text-orange-500">ACADEMY</span></div>
        </nav>
        <main class="flex-1 flex items-center justify-center">
            <div class="max-w-xl w-full bg-white p-12 rounded-3xl shadow-xl text-center border">
                <h1 class="text-3xl font-black text-[#14316d] mb-4">Calculus Mastery</h1>
                <p class="text-zinc-500 mb-8">Resume your session on <b>Derivatives & Integrals</b>.</p>
                <button onclick="handshake()" class="bg-orange-500 text-white px-12 py-5 rounded-2xl font-black">RESUME LESSON</button>
            </div>
        </main>
    </div>

    <div id="rem-os">
        <div class="os-sidebar">
            <div class="text-white font-black italic text-lg px-2 mb-6 border-b border-zinc-800 pb-4">REMS_OS_v36.0</div>
            <button onclick="showTab('mc')" id="side-mc" class="btn-bulky active-side">⛏️ MINECRAFT_OFFICIAL</button>
            <button onclick="showTab('br')" id="side-br" class="btn-bulky">🌐 BOREHOLE_BROWSER</button>
            <button onclick="showTab('cl')" id="side-cl" class="btn-bulky">🔢 OG_CALCULATOR</button>
            <button onclick="closeOS()" class="btn-bulky mt-auto text-red-500 text-center">SHUTDOWN</button>
        </div>

        <div class="flex-1 overflow-hidden">
            <div id="tab-mc" class="os-tab active-tab">
                <div class="mc-window">
                    <div class="mc-left-nav">
                        <div class="mc-game-icon active" style="background-image: url('https://upload.wikimedia.org/wikipedia/en/5/51/Minecraft_cover.png');"></div>
                        <div class="mc-game-icon" style="background-image: url('https://upload.wikimedia.org/wikipedia/en/8/8e/Minecraft_Dungeons_cover_art.jpg');"></div>
                    </div>
                    <div class="mc-content">
                        <div class="mc-header">
                            <span class="active">PLAY</span>
                            <span>INSTALLATIONS</span>
                            <span>SKINS</span>
                            <span>PATCH NOTES</span>
                        </div>
                        <div class="mc-hero">
                            <div class="text-white text-5xl font-black italic" style="text-shadow: 3px 3px 0 #000">MINECRAFT</div>
                            <div class="text-zinc-400 font-bold mt-1">Java Edition | 1.21.x</div>
                        </div>
                        <div class="p-6">
                            <div class="bg-[#2b2b2b] p-4 rounded border border-zinc-700">
                                <div class="text-green-500 text-[10px] font-bold">LATEST RELEASE</div>
                                <div class="text-white font-bold mt-1">Snapshot 26w12a</div>
                                <div class="text-zinc-400 text-[10px] mt-1">Fixing connection issues in regional school networks.</div>
                            </div>
                        </div>
                        <div class="mc-play-bar">
                            <div class="mc-play-btn" onclick="borehole('https://tuff-client.github.io/')">PLAY</div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="tab-br" class="os-tab flex flex-col items-center justify-center bg-[#1a1a1a]">
                <div class="bg-[#2b2b2b] p-10 rounded-2xl border-4 border-zinc-800 w-[500px]">
                    <h3 class="text-white font-black mb-6 uppercase tracking-widest text-blue-500">Borehole v2.0</h3>
                    <input type="text" id="br-input" class="w-full bg-black border border-zinc-700 p-4 text-white rounded mb-4" placeholder="URL or Search Terms...">
                    <button onclick="borehole(document.getElementById('br-input').value)" class="w-full bg-blue-600 text-white font-bold py-4 rounded">DIRECT INJECT</button>
                </div>
            </div>

            <div id="tab-cl" class="os-tab flex items-center justify-center">
                <div class="ti-case">
                    <div class="ti-lcd" id="display">0</div>
                    <div class="grid grid-cols-4 gap-3">
                        <button class="ti-key key-orange" onclick="toggle2nd()" id="btn-2nd">2nd</button>
                        <button class="ti-key key-red" onclick="reset()">AC</button>
                        <button class="ti-key key-red" onclick="del()">DEL</button>
                        <button class="ti-key" onclick="press('/')">÷</button>
                        
                        <button class="ti-key" onclick="press('7')">7</button>
                        <button class="ti-key" onclick="press('8')">8</button>
                        <button class="ti-key" onclick="press('9')">9</button>
                        <button class="ti-key" onclick="press('*')">×</button>
                        
                        <button class="ti-key" onclick="press('4')">4</button>
                        <button class="ti-key" onclick="press('5')">5</button>
                        <button class="ti-key" onclick="press('6')">6</button>
                        <button class="ti-key" onclick="press('-')">−</button>
                        
                        <button class="ti-key" onclick="press('1')">1</button>
                        <button class="ti-key" onclick="press('2')">2</button>
                        <button class="ti-key" onclick="press('3')">3</button>
                        <button class="ti-key" onclick="press('+')">+</button>
                        
                        <button class="ti-key col-span-2" onclick="press('0')">0</button>
                        <button class="ti-key" onclick="press('.')">.</button>
                        <button class="ti-key key-orange" onclick="evalCalc()">ENTER</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let clicks = 0; let v = "0"; let is2nd = false;

        function handshake() {
            clicks++;
            if(clicks >= 3) { openOS(); clicks = 0; }
            setTimeout(() => clicks = 0, 1000);
        }

        // BOREHOLE 2.0: Blob Constructor Bypass
        function borehole(target) {
            if (!target) return;
            let url = target.includes('.') ? (target.startsWith('http') ? target : 'https://' + target) : `https://www.google.com/search?q=${encodeURIComponent(target)}&igu=1`;
            
            const win = window.open('about:blank', '_blank');
            if (!win) { alert("Enable Pop-ups for Bypass!"); return; }

            const html = `<html><body style="margin:0;padding:0;height:100vh;overflow:hidden;"><iframe src="${url}" style="width:100%;height:100%;border:none;" allow="autoplay; fullscreen; gamepad; pointer-lock;"></iframe></body></html>`;
            const blob = new Blob([html], { type: 'text/html' });
            win.location.href = URL.createObjectURL(blob);
        }

        function showTab(t) {
            document.querySelectorAll('.os-tab').forEach(x => x.classList.remove('active-tab'));
            document.querySelectorAll('.btn-bulky').forEach(x => x.classList.remove('active-side'));
            document.getElementById('tab-' + t).classList.add('active-tab');
            document.getElementById('side-' + t).classList.add('active-side');
        }

        function openOS() { document.getElementById('rem-os').style.display = 'grid'; }
        function closeOS() { document.getElementById('rem-os').style.display = 'none'; }
        function panic() { closeOS(); reset(); }

        function press(n) { v = (v === "0" ? n : v + n); document.getElementById('display').innerText = v; }
        function del() { v = v.slice(0, -1) || "0"; document.getElementById('display').innerText = v; }
        function reset() { v = "0"; document.getElementById('display').innerText = "0"; }
        function toggle2nd() { is2nd = !is2nd; document.getElementById('btn-2nd').style.filter = is2nd ? 'brightness(1.5)' : 'none'; }
        function evalCalc() {
            if(is2nd) { closeOS(); toggle2nd(); }
            else { try { v = String(eval(v.replace('×','*').replace('÷','/').replace('−','-'))); document.getElementById('display').innerText = v; } catch { document.getElementById('display').innerText = "ERR"; } }
        }
    </script>
</body>
</html>
