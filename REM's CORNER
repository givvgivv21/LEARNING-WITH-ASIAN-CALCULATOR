<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Rem's Melons :D</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@700&family=Syncopate:wght@700&display=swap" rel="stylesheet">
    <style>
        :root { 
            --rind: #1a3c1a; 
            --flesh: #ff4d4d; 
            --seed: #111111;
            --neon-g: #39ff14;
        }
        body, html { 
            margin: 0; padding: 0; height: 100vh; 
            background: var(--seed);
            font-family: 'Fira Code', monospace; 
            overflow: hidden; 
            display: flex;
        }

        /* LEFT SIDEBAR - THE RIND */
        .sidebar {
            width: 450px; height: 100%;
            background: linear-gradient(to bottom, var(--rind), #0a1a0a);
            border-right: 4px solid var(--neon-g);
            display: flex; flex-direction: column;
            padding: 40px;
            box-shadow: 10px 0 30px rgba(0,0,0,0.5);
            z-index: 10;
        }

        /* MAIN TERMINAL - THE FLESH */
        .main-stage {
            flex-grow: 1;
            background: radial-gradient(circle at center, #2d0a0a 0%, #111 100%);
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            position: relative;
        }

        .watermelon-hero {
            font-size: 120px;
            filter: drop-shadow(0 0 20px var(--flesh));
            margin-bottom: 20px;
            animation: bounce 3s ease-in-out infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }

        .ascii-brand {
            font-size: 7px; line-height: 7px;
            color: var(--neon-g); white-space: pre;
            margin-bottom: 30px;
            text-shadow: 0 0 5px var(--neon-g);
        }

        /* BUTTONS */
        .nav-item {
            padding: 18px 25px;
            margin-bottom: 12px;
            background: rgba(0,0,0,0.3);
            border: 2px solid var(--flesh);
            color: white;
            font-weight: 700;
            cursor: pointer;
            transition: 0.2s;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex; justify-content: space-between;
        }
        .nav-item:hover {
            background: var(--flesh);
            color: var(--seed);
            transform: translateX(10px);
            box-shadow: -5px 0 0 var(--neon-g);
        }

        .status-bar {
            position: absolute; bottom: 20px; left: 20px;
            color: var(--neon-g); font-size: 10px;
        }

        h2 { color: var(--flesh); font-family: 'Syncopate'; font-size: 1.5rem; margin-bottom: 10px; }
    </style>
</head>
<body onkeydown="if(event.key==='Escape'){panic()}">

    <div class="sidebar">
        <div class="mb-8">
            <h2>Rem's Melons :D</h2>
            <p class="text-[10px] text-green-400 tracking-[3px]">MELON-CORE v81.0 // ACTIVE</p>
        </div>

        <div class="ascii-brand">
++++++   +++++++  ++      ++   +++++++  
++   ++  ++       +++    +++  ++        
++   ++  +++++    ++ +  + ++  +++++++   
++++++   ++       ++  ++  ++        ++  
++  ++   ++       ++      ++        ++  
++   ++  +++++++  ++      ++   +++++++  

+++++++   ++++++   +++++++   ++   ++  +++++++  ++++++  
++       ++    ++  ++    ++  +++  ++  ++       ++   ++ 
++       ++    ++  +++++++   ++ + ++  +++++    ++++++  
++       ++    ++  ++  ++    ++  +++  ++       ++  ++  
+++++++   ++++++   ++   ++   ++   ++  +++++++  ++   ++
</div>

        <div class="nav-item" onclick="melonLaunch('https://eaglercraft.q13x.com/', 'Bio-Assignment')">
            <span>UNLOCKED: MINECRAFT</span><span>[>]</span>
        </div>
        <div class="nav-item" onclick="melonLaunch('https://takaiwebsite.neocities.org/brotato', 'Data Analysis')">
            <span>UNLOCKED: BROTATO</span><span>[>]</span>
        </div>
        <div class="nav-item" onclick="melonLaunch('https://www.google.com/search?igu=1', 'Google Classroom')">
            <span>UNLOCKED: GOOGLE</span><span>[>]</span>
        </div>
        <div class="nav-item" onclick="spawnAI()">
            <span>ACCESS: MELON_AI</span><span>[+]</span>
        </div>

        <div class="mt-auto nav-item" style="border-color: #fff; color: #fff;" onclick="panic()">
            <span>EMERGENCY WIPE</span><span>[ESC]</span>
        </div>
    </div>

    <div class="main-stage">
        <div class="watermelon-hero">🍉</div>
        <div class="text-white text-4xl font-black mb-2 italic">REM'S MELONS</div>
        <div class="text-red-500 font-bold tracking-widest">ENCRYPTED WINDOW DEPLOYMENT READY</div>
        
        <div class="status-bar">
            [SYS] WINDOW_POPUP_ENABLED: TRUE <br>
            [SYS] BLOB_INJECTION: ACTIVE <br>
            [SYS] MASK_MODE: EDUCATIONAL
        </div>
    </div>

    <script>
        let openWindows = [];

        function melonLaunch(url, maskTitle) {
            // Calculate screen center for the new window
            const w = 1200;
            const h = 800;
            const left = (screen.width/2)-(w/2);
            const top = (screen.height/2)-(h/2);

            // Open in a completely new window, not a tab
            const newWin = window.open('about:blank', '_blank', 
                `width=${w},height=${h},top=${top},left=${left},menubar=no,status=no,toolbar=no`);

            if(!newWin) {
                alert("🚨 POPUP BLOCKED! You must allow popups for Rem's Melons to work! 🍉");
                return;
            }

            const blob = new Blob([`
                <html>
                <head>
                    <title>${maskTitle}</title>
                    <style>
                        body,html,iframe{margin:0;padding:0;height:100%;width:100%;background:#000;border:none;overflow:hidden;}
                    </style>
                </head>
                <body>
                    <iframe src="${url}" referrerpolicy="no-referrer"></iframe>
                </body>
                </html>
            `], {type: 'text/html'});

            newWin.location.href = URL.createObjectURL(blob);
            openWindows.push(newWin);
        }

        function spawnAI() {
            const aiWin = window.open('', '', 'width=500,height=600');
            aiWin.document.write(`
                <body style="background:#111;color:#39ff14;font-family:monospace;padding:30px;border:10px solid #1a3c1a;">
                    <h1 style="color:#ff4d4d">MELON_AI v81</h1>
                    <p>Seed-Logic stable. Minecraft Launcher tunnel established.</p>
                </body>
            `);
            openWindows.push(aiWin);
        }

        function panic() {
            openWindows.forEach(w => {
                if(!w.closed) w.close();
            });
            openWindows = [];
            location.reload();
        }
    </script>
</body>
</html>
