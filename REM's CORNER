<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>TI-84 Plus | Graphing Calculator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <style>
        :root { --ti-bg: #343a40; --ti-lcd: #94a891; --ti-orange: #ff922b; --ti-red: #e03131; }
        body, html { margin: 0; padding: 0; height: 100vh; background: #121212; display: flex; justify-content: center; align-items: center; font-family: sans-serif; overflow: hidden; }

        /* THE OG CALCULATOR GUI */
        .ti-frame { background: var(--ti-bg); border: 8px solid #1a1a1a; border-radius: 24px; padding: 35px; width: 420px; box-shadow: 0 30px 60px rgba(0,0,0,0.9); position: relative; }
        .ti-lcd { background: var(--ti-lcd); border: 12px solid #111; height: 110px; margin-bottom: 30px; padding: 15px; font-family: 'JetBrains Mono'; font-size: 2.6rem; text-align: right; color: #1a1a1a; box-shadow: inset 5px 5px 10px rgba(0,0,0,0.4); line-height: 80px; }
        .ti-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; }
        .ti-btn { background: #495057; color: white; border-radius: 6px; border-bottom: 6px solid #212529; font-weight: 800; padding: 20px 0; font-size: 1.2rem; text-align: center; cursor: pointer; user-select: none; }
        .ti-btn:active { transform: translateY(4px); border-bottom-width: 2px; }
        .orange { background: var(--ti-orange) !important; color: #000; }
        .red { background: var(--ti-red) !important; }

        .status-led { position: absolute; top: 15px; right: 40px; width: 8px; height: 8px; background: #222; border-radius: 50%; }
        .led-on { background: #0f0; box-shadow: 0 0 5px #0f0; }
    </style>
</head>
<body onkeydown="if(event.key==='~'){panic()}">

    <div class="ti-frame">
        <div class="status-led" id="led"></div>
        <div class="ti-lcd" id="display">0</div>
        <div class="ti-grid">
            <div class="ti-btn orange" onclick="handle('2nd')">2nd</div>
            <div class="ti-btn red" onclick="handle('AC')">AC</div>
            <div class="ti-btn red" onclick="handle('DEL')">DEL</div>
            <div class="ti-btn" onclick="handle('/')">/</div>
            
            <div class="ti-btn" onclick="handle('7')">7</div>
            <div class="ti-btn" onclick="handle('8')">8</div>
            <div class="ti-btn" onclick="handle('9')">9</div>
            <div class="ti-btn" onclick="handle('*')">*</div>
            
            <div class="ti-btn" onclick="handle('4')">4</div>
            <div class="ti-btn" onclick="handle('5')">5</div>
            <div class="ti-btn" onclick="handle('6')">6</div>
            <div class="ti-btn" onclick="handle('-')">-</div>
            
            <div class="ti-btn" onclick="handle('1')">1</div>
            <div class="ti-btn" onclick="handle('2')">2</div>
            <div class="ti-btn" onclick="handle('3')">3</div>
            <div class="ti-btn" onclick="handle('+')">+</div>
            
            <div class="ti-btn" onclick="handle('0')">0</div>
            <div class="ti-btn" onclick="handle('.')">.</div>
            <div class="ti-btn orange col-span-2" onclick="handle('ENTER')">ENTER</div>
        </div>
    </div>

    <script>
        let val = "0"; let isShift = false;
        const MC_URL = "https://takaiwebsite.neocities.org/minecraft";
        const BROTATO_URL = "https://brotato.io/"; // Optimized Brotato Mirror

        function handle(k) {
            if (k === '2nd') { 
                isShift = !isShift; 
                document.getElementById('led').classList.toggle('led-on', isShift);
                document.getElementById('display').innerText = isShift ? "2nd..." : val;
                return; 
            }
            
            if (isShift) {
                if (k === '7') spawnLauncher(); 
                if (k === '8') spawnBrotato(); 
                if (k === '9') spawnGame();     
                if (k === 'ENTER') panic();      
                isShift = false;
                document.getElementById('led').classList.remove('led-on');
                return;
            }

            if (k === 'AC') val = "0";
            else if (k === 'DEL') val = val.slice(0, -1) || "0";
            else if (k === 'ENTER') {
                try { val = String(eval(val.replace('×','*').replace('÷','/'))); } catch { val = "ERR"; }
            } else { val = (val === "0" ? k : val + k); }
            document.getElementById('display').innerText = val;
        }

        function spawnLauncher() {
            const win = window.open('', '_blank', 'width=1100,height=750');
            win.document.write(`
                <html><head><title>Minecraft Launcher</title>
                <style>
                    body { margin:0; background:#1a1a1a; font-family:sans-serif; color:white; overflow:hidden; }
                    .mc-window { display:flex; height:100vh; }
                    .sidebar { width:70px; background:#181818; display:flex; flex-direction:column; align-items:center; padding-top:20px; border-right:1px solid #333; }
                    .main { flex:1; display:flex; flex-direction:column; }
                    .nav { height:50px; background:#212121; display:flex; align-items:center; padding-left:30px; gap:25px; font-size:12px; font-weight:bold; border-bottom:1px solid #333; }
                    .nav span:hover { color:#3c8527; cursor:pointer; }
                    .hero { flex:1; background:linear-gradient(rgba(0,0,0,0.3), #1a1a1a), url('https://minecraft.net/content/dam/minecraftnet/games/minecraft/key-art/MC-Home-Hero-Desktop.jpg'); background-size:cover; padding:40px; display:flex; flex-direction:column; justify-content:flex-end; }
                    .footer { height:100px; background:#1e1e1e; border-top:1px solid #333; display:flex; align-items:center; justify-content:center; gap:20px; }
                    .play-btn { background:#3c8527; width:220px; height:50px; border-radius:4px; font-size:24px; font-weight:900; display:flex; align-items:center; justify-content:center; cursor:pointer; box-shadow:0 4px 0 #2a5d1b; }
                    .mod-btn { background:#444; width:120px; height:50px; border-radius:4px; font-weight:bold; display:flex; align-items:center; justify-content:center; cursor:pointer; }
                </style></head>
                <body><div class="mc-window">
                    <div class="sidebar"><div style="width:45px;height:45px;background:#333;border:2px solid #fff;border-radius:6px;"></div></div>
                    <div class="main">
                        <div class="nav"><span>PLAY</span><span>INSTALLATIONS</span><span>SKINS</span><span onclick="alert('Mod Folder Opened: Import .jar or .png below')">MODS</span></div>
                        <div class="hero"><h1>MINECRAFT</h1><p>Java Edition</p></div>
                        <div class="footer">
                            <div class="play-btn" onclick="location.href='${MC_URL}'">PLAY</div>
                            <label class="mod-btn">IMPORT PNG<input type="file" accept="image/png" style="display:none"></label>
                            <label class="mod-btn">ADD MODS<input type="file" accept=".jar,.zip" style="display:none"></label>
                        </div>
                    </div>
                </div></body></html>
            `);
        }

        function spawnBrotato() {
            const win = window.open('', '_blank', 'width=1200,height=850');
            win.document.write(`<html><body style="margin:0;background:black;"><iframe src="${BROTATO_URL}" style="width:100vw;height:100vh;border:none;"></iframe></body></html>`);
        }

        function spawnGame() {
            const win = window.open('', '_blank', 'width=1200,height=800');
            win.document.write(`<html><body style="margin:0;background:black;"><iframe src="${MC_URL}" style="width:100vw;height:100vh;border:none;"></iframe></body></html>`);
        }

        function panic() {
            val = "0"; document.getElementById('display').innerText = "0";
            document.getElementById('led').classList.remove('led-on');
        }
    </script>
</body>
</html>
