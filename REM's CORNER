<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>TI-84 Plus 2nd Edition | v67 Specter-Grid</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@800&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #2d2d2d; --lcd: #8b9a84; --orange: #f0810f; --mc-green: #3c8527; }
        body, html { margin: 0; padding: 0; height: 100vh; background: #000; font-family: 'JetBrains Mono', monospace; overflow: hidden; }

        /* ROTATING ANGEL HALO */
        .halo { position: absolute; top: -45px; left: 50%; transform: translateX(-50%); width: 150px; height: 40px; border: 4px solid #fff; border-radius: 50%; opacity: 0; filter: blur(1px) drop-shadow(0 0 15px #fff); z-index: 5; pointer-events: none; transition: 0.5s; }
        .halo-active { opacity: 0.8; animation: rotateHalo 4s linear infinite; }
        @keyframes rotateHalo { 0% { transform: translateX(-50%) rotateX(60deg) rotateZ(0deg); } 100% { transform: translateX(-50%) rotateX(60deg) rotateZ(360deg); } }

        /* CALC CASE */
        .calc-case { background: var(--bg); border: 2px solid #111; width: 400px; padding: 30px; border-radius: 4px; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10; box-shadow: 20px 20px 0px #111; }
        .calc-lcd { background: var(--lcd); border: 4px solid #111; height: 85px; margin-bottom: 25px; padding: 10px; font-size: 2.2rem; text-align: right; color: #1a1a1a; line-height: 65px; box-shadow: inset 3px 3px 0px rgba(0,0,0,0.1); }
        .calc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
        .btn { background: #4a4a4a; color: #fff; border-bottom: 4px solid #1a1a1a; font-size: 1.1rem; font-weight: 800; padding: 15px 0; text-align: center; cursor: pointer; user-select: none; transition: 0.1s; }
        .btn:active { transform: translateY(2px); border-bottom-width: 2px; }
        .orange { background: var(--orange) !important; color: #000 !important; }

        /* COMMAND CENTER SIDEBAR */
        #dash { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 10000; flex-direction: row; align-items: center; justify-content: center; backdrop-filter: blur(10px); }
        .sidebar-grid { display: grid; grid-template-columns: repeat(3, 120px); gap: 30px; }
        .app-card { background: #111; border: 1px solid #333; height: 120px; display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; border-radius: 15px; transition: 0.3s; }
        .app-card:hover { border-color: var(--orange); background: #1a1a1a; transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.5); }
        .app-card span { font-size: 10px; margin-top: 10px; font-weight: 900; color: #666; }
        .app-card:hover span { color: var(--orange); }

        /* BOOT OVERLAY */
        #boot-screen { display: none; position: fixed; inset: 0; background: var(--orange); z-index: 20000; flex-direction: column; align-items: center; justify-content: center; }
        .loader-bar { width: 300px; height: 6px; background: rgba(255,255,255,0.2); border-radius: 10px; overflow: hidden; margin-top: 25px; }
        .loader-fill { width: 0%; height: 100%; background: #fff; }
    </style>
</head>
<body onkeydown="if(event.key==='~'){panic()}">

    <div class="calc-case">
        <div class="halo" id="halo"></div>
        <div id="display" class="calc-lcd">0</div>
        <div class="calc-grid">
            <div class="btn orange" onclick="press('2nd')">2nd</div>
            <div class="btn" onclick="press('AC')">AC</div>
            <div class="btn" onclick="press('/')">/</div>
            <div class="btn" onclick="press('*')">*</div>
            <div class="btn" onclick="press('7')">7</div>
            <div class="btn" onclick="press('8')">8</div>
            <div class="btn" onclick="press('9')">9</div>
            <div class="btn" onclick="press('-')">-</div>
            <div class="btn" onclick="press('4')">4</div>
            <div class="btn" onclick="press('5')">5</div>
            <div class="btn" onclick="press('6')">6</div>
            <div class="btn" onclick="press('+')">+</div>
            <div class="btn" onclick="press('1')">1</div>
            <div class="btn" onclick="press('2')">2</div>
            <div class="btn" onclick="press('3')">3</div>
            <div class="btn orange col-span-1" onclick="press('ENTER')">EXE</div>
            <div class="btn col-span-2" onclick="press('0')">0</div>
            <div class="btn" onclick="press('.')">.</div>
        </div>
    </div>

    <div id="dash">
        <div class="sidebar-grid">
            <div class="app-card" onclick="spawn('mc')">
                <div class="w-10 h-10 bg-green-700 rounded-sm"></div>
                <span>MINECRAFT</span>
            </div>
            <div class="app-card" onclick="spawn('git')">
                <div class="w-10 h-10 bg-zinc-700 rounded-full"></div>
                <span>GITHUB</span>
            </div>
            <div class="app-card" onclick="spawn('brt')">
                <div class="w-10 h-10 bg-red-700 rounded-sm"></div>
                <span>BROTATO</span>
            </div>
            <div class="app-card" onclick="spawn('ai')">
                <div class="w-10 h-10 bg-orange-600 rounded-lg"></div>
                <span>REM_AI</span>
            </div>
            <div class="app-card" onclick="spawn('web')">
                <div class="w-10 h-10 bg-blue-600 rounded-full"></div>
                <span>BROWSER</span>
            </div>
            <div class="app-card border-red-900" onclick="panic()">
                <div class="w-10 h-10 bg-red-900 flex items-center justify-center font-black">X</div>
                <span class="text-red-600">PANIC</span>
            </div>
        </div>
    </div>

    <div id="boot-screen">
        <div class="text-7xl font-black italic text-white">MOJANG</div>
        <div class="loader-bar"><div id="boot-fill" class="loader-fill"></div></div>
        <p id="boot-msg" class="text-white font-bold mt-6 text-xs tracking-widest uppercase">Initializing Ghost Window...</p>
    </div>

    <script>
        let cur = "0"; 
        let is2nd = false;
        let ghostWindows = [];

        const routes = {
            mc: "https://eaglercraft.com/mc/1.8.8/",
            git: "https://github.com/givvgivv21/LEARNING-WITH-ASIAN-CALCULATOR",
            brt: "https://takaiwebsite.neocities.org/brotato",
            ai: "https://chat.openai.com", // Or a local sim page
            web: "https://www.google.com/search?igu=1"
        };

        function press(k) {
            if (k === '2nd') { 
                is2nd = !is2nd; 
                document.getElementById('halo').classList.toggle('halo-active', is2nd);
                return; 
            }
            if (is2nd && k === 'ENTER') { 
                document.getElementById('dash').style.display = 'flex'; 
                return; 
            }
            if (k === 'AC') panic();
            else if (k === 'ENTER') try { cur = eval(cur.replace('×','*').replace('÷','/')) + ""; } catch { cur = "ERR"; }
            else cur = (cur === "0" ? k : cur + k);
            document.getElementById('display').innerText = cur;
        }

        function spawn(app) {
            const boot = document.getElementById('boot-screen');
            const fill = document.getElementById('boot-fill');
            const msg = document.getElementById('boot-msg');
            
            boot.style.display = 'flex';
            fill.style.width = '0%';
            msg.innerText = `Spawning ${app.toUpperCase()} Ghost...`;
            
            let p = 0;
            let int = setInterval(() => {
                p += 10;
                fill.style.width = p + '%';
                if (p >= 100) {
                    clearInterval(int);
                    boot.style.display = 'none';
                    
                    // WIN LOGIC
                    const win = window.open(routes[app], `_blank`, `width=1000,height=700,menubar=no,status=no,toolbar=no`);
                    if(win) {
                        ghostWindows.push(win);
                        document.getElementById('dash').style.display = 'none';
                    } else {
                        alert("POPUP BLOCKED! Please enable popups in your browser settings to launch apps.");
                    }
                }
            }, 30);
        }

        function panic() {
            // Kill all separate windows
            ghostWindows.forEach(win => {
                if(!win.closed) win.close();
            });
            ghostWindows = [];
            // Reset main UI
            document.getElementById('dash').style.display = 'none';
            document.getElementById('halo').classList.remove('halo-active');
            is2nd = false;
            cur = "0";
            document.getElementById('display').innerText = "0";
            location.reload();
        }
    </script>
</body>
</html>
