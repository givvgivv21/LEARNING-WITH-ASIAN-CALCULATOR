<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rem's Corner | Potato Core v12</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/skinview3d@3.0.0/dist/skinview3d.bundle.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <style>
        :root { --red: #dc2626; --orange: #f97316; }
        body { background: radial-gradient(circle at top left, #450a0a 0%, #09090b 100%); color: #fff; font-family: 'Plus Jakarta Sans', sans-serif; height: 100vh; overflow: hidden; margin: 0; }
        
        /* Stealth UI */
        .widget { background: rgba(20, 20, 25, 0.9); padding: 2rem; border-radius: 50px; border: 1px solid rgba(220, 38, 38, 0.3); }
        .screen { background: #000; border-radius: 25px; padding: 1.2rem; margin-bottom: 1.2rem; text-align: right; font-family: 'JetBrains Mono'; color: var(--orange); font-size: 2rem; border: 1px solid var(--red); }
        .key { height: 50px; border-radius: 25px; background: rgba(255, 255, 255, 0.03); font-weight: 800; cursor: pointer; transition: 0.2s; color: #fecaca; }
        .key:hover { background: var(--red); color: white; transform: translateY(-2px); }
        .key-active { background: var(--orange); box-shadow: 0 0 20px var(--orange); }

        /* MULTI-LAUNCHER UI */
        .os-window { display: flex; height: 550px; background: #1a1b1e; border-radius: 12px; overflow: hidden; border: 1px solid #333; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); }
        .os-sidebar { width: 220px; background: #000; padding: 20px 10px; display: flex; flex-direction: column; gap: 8px; border-right: 1px solid #222; }
        .os-nav-item { padding: 12px 15px; border-radius: 8px; font-size: 13px; font-weight: 700; color: #888; cursor: pointer; transition: 0.2s; }
        .os-nav-item:hover { background: rgba(220, 38, 38, 0.1); color: #fff; }
        .os-nav-item.active { background: var(--red); color: #fff; }
        
        .os-main { flex: 1; position: relative; background: #111; }
        .os-footer { position: absolute; bottom: 0; width: 100%; height: 90px; background: rgba(0,0,0,0.85); display: flex; align-items: center; padding: 0 30px; justify-content: space-between; border-top: 1px solid #333; }
        
        .play-btn { background: #3c8527; padding: 12px 60px; color: white; font-weight: 900; font-size: 24px; border-radius: 4px; border-bottom: 4px solid #2a5d1b; cursor: pointer; transition: 0.1s; }
        .play-btn:active { transform: translateY(2px); border-bottom-width: 0; }
        .play-btn.brotato-theme { background: #f97316; border-bottom-color: #c2410c; }

        #rem-os { position: fixed; inset: 0; background: #0a0a0c; z-index: 5000; display: none; flex-direction: column; border-top: 4px solid var(--red); }
        #skin-container { width: 100%; height: 350px; background: rgba(0,0,0,0.5); border-radius: 12px; }
    </style>
</head>
<body>

    <nav class="p-6 px-12 flex justify-between items-center border-b border-red-900/30">
        <div class="font-black text-2xl tracking-tighter text-white">REMS<span class="text-orange-500">CORNER</span></div>
        <div class="flex gap-4">
            <button onclick="downloadSelf()" class="bg-red-600 text-white px-6 py-2 rounded-full font-bold text-[10px] uppercase">Export v12</button>
        </div>
    </nav>

    <div class="grid grid-cols-[1fr_380px] gap-8 p-12 h-[calc(100vh-100px)]">
        <div class="bg-red-950/10 border border-red-500/20 p-10 rounded-[50px] backdrop-blur-md">
            <h1 class="text-5xl font-black mb-4 italic text-white uppercase tracking-tighter">Potato <span class="text-orange-500">Core</span></h1>
            <p class="text-red-100/60 leading-relaxed text-lg mb-8">Brotato Web Engine v1.0 Integrated. Multi-game focus injection enabled. Enter code to unlock the Arena.</p>
        </div>

        <div class="widget">
            <div class="screen" id="calc-val">0</div>
            <div class="grid grid-cols-4 gap-2">
                <button id="btn-2nd" class="key" onclick="toggle2nd()">2nd</button>
                <button class="key" onclick="deleteChar()">DEL</button>
                <button class="key" onclick="handleClear()">AC</button>
                <button class="key text-orange-500" onclick="handleTuff()">÷</button>
                <button class="key" onclick="append('7')">7</button>
                <button class="key" onclick="append('8')">8</button>
                <button class="key" onclick="append('9')">9</button>
                <button class="key text-orange-500" onclick="append('*')">×</button>
                <button class="key" onclick="append('4')">4</button>
                <button class="key" onclick="append('5')">5</button>
                <button class="key" onclick="append('6')">6</button>
                <button class="key text-orange-500" onclick="append('-')">-</button>
                <button class="key" onclick="append('1')">1</button>
                <button class="key" onclick="append('2')">2</button>
                <button class="key" onclick="append('3')">3</button>
                <button class="key text-orange-500" onclick="append('+')">+</button>
                <button class="key col-span-2" onclick="append('0')">0</button>
                <button class="key" onclick="append('.')">.</button>
                <button class="key bg-gradient-to-br from-red-600 to-orange-600 text-white border-none" onclick="handleEnter()">=</button>
            </div>
        </div>
    </div>

    <div id="rem-os">
        <div class="flex flex-1">
            <div class="w-64 bg-black p-8 border-r border-red-900/30 flex flex-col gap-2">
                <div class="text-[10px] font-black text-red-600 mb-6 tracking-widest uppercase">Select Environment</div>
                <button onclick="showTab('mc')" class="text-left p-4 rounded-xl hover:bg-red-900/20 font-bold transition">🎮 Minecraft</button>
                <button onclick="showTab('bt')" class="text-left p-4 rounded-xl hover:bg-orange-900/20 font-bold transition text-orange-500">🥔 Brotato</button>
                <button onclick="showTab('prox')" class="text-left p-4 rounded-xl hover:bg-red-900/20 font-bold transition">📄 Proxy Vault</button>
                <button onclick="closeOS()" class="mt-auto text-red-500 font-black text-[10px] text-center p-4 hover:text-white transition">[TERMINATE]</button>
            </div>

            <div class="flex-1 p-10 bg-[#09090b] overflow-y-auto">
                
                <div id="tab-mc" class="os-tab">
                    <div class="os-window">
                        <div class="os-sidebar">
                            <div class="os-nav-item active">Launcher</div>
                            <div class="os-nav-item" onclick="toggleSkins()">Skins</div>
                        </div>
                        <div class="os-main" style="background: url('https://minecraft.net/content/dam/minecraftnet/games/minecraft/key-art/MC-Home-Hero-Desktop.jpg') center/cover;">
                            <div id="skin-overlay" class="hidden absolute inset-0 bg-[#2b2b2b] p-8 flex flex-col items-center">
                                <div id="skin-container"></div>
                                <button onclick="document.getElementById('skin-upload').click()" class="mt-4 px-6 py-2 bg-white text-black font-bold text-xs rounded">UPLOAD PNG</button>
                                <input type="file" id="skin-upload" class="hidden" onchange="loadSkin(this)">
                            </div>
                            <div class="os-footer">
                                <div><div class="text-white font-bold text-sm uppercase">Java Edition</div><div class="text-gray-400 text-[10px]">Ver: Forge 1.12.2</div></div>
                                <button class="play-btn" onclick="launchGame('https://takaiwebsite.neocities.org/minecraft')">PLAY</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="tab-bt" class="os-tab hidden">
                    <div class="os-window" style="border-color: var(--orange);">
                        <div class="os-sidebar" style="border-right-color: #431407;">
                            <div class="os-nav-item active" style="color: var(--orange);">Brotato Arena</div>
                            <div class="os-nav-item">Character Planner</div>
                        </div>
                        <div class="os-main" style="background: url('https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/1942280/ss_49339e1451f1624c80330058e5793083f2a11b66.1920x1080.jpg?t=1706692807') center/cover;">
                            <div class="os-footer" style="border-top-color: #431407;">
                                <div><div class="text-orange-500 font-bold text-sm uppercase">Potato Core v1.0</div><div class="text-gray-400 text-[10px]">Arena: Web High-Performance</div></div>
                                <button class="play-btn brotato-theme" onclick="launchGame('https://6499806e57922d0d0879624d--unrivaled-sable-516a7c.netlify.app/')">START WAVE</button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        let is2nd = false; let input = "0"; let skinViewer;

        window.onload = () => {
            skinViewer = new skinview3d.SkinViewer({ canvas: document.getElementById("skin-container"), width: 300, height: 350, skin: "https://minotar.net/skin/char" });
            skinViewer.autoRotate = true; skinViewer.animation = new skinview3d.WalkingAnimation();
        };

        function launchGame(url) {
            const win = window.open("about:blank", "_blank");
            win.document.write(`
                <html><head><title>System.Execute</title><style>body,html{margin:0;padding:0;height:100%;background:#000;overflow:hidden;}iframe{width:100vw;height:100vh;border:none;}</style></head>
                <body><iframe id="game-frame" src="${url}" allow="autoplay; fullscreen; gamepad; pointer-lock" sandbox="allow-forms allow-modals allow-pointer-lock allow-popups allow-same-origin allow-scripts"></iframe>
                <script>window.onload = () => { const f = document.getElementById('game-frame'); f.focus(); document.body.onclick = () => f.focus(); };<\/script>
                </body></html>
            `);
        }

        function toggleSkins() { document.getElementById('skin-overlay').classList.toggle('hidden'); }
        function loadSkin(input) { if (input.files && input.files[0]) { const r = new FileReader(); r.onload = (e) => skinViewer.loadSkin(e.target.result); r.readAsDataURL(input.files[0]); } }
        function downloadSelf() { const b = new Blob([document.documentElement.outerHTML], {type: "text/html"}); const a = document.createElement("a"); a.href = URL.createObjectURL(b); a.download = "Rems_Corner_v12_PotatoCore.html"; a.click(); }

        function toggle2nd() { is2nd = !is2nd; document.getElementById('btn-2nd').classList.toggle('key-active', is2nd); }
        function append(v) { input = input === "0" ? v : input + v; document.getElementById('calc-val').innerText = input; }
        function deleteChar() { input = input.slice(0, -1) || "0"; document.getElementById('calc-val').innerText = input; }
        function handleClear() { input = "0"; document.getElementById('calc-val').innerText = "0"; }
        function handleTuff() { if(is2nd) { openOS(); showTab('mc'); toggle2nd(); } else append('/'); }
        function handleEnter() { if(is2nd) { openOS(); toggle2nd(); } else { try { input = String(eval(input.replace('×','*').replace('÷','/'))); document.getElementById('calc-val').innerText = input; } catch { document.getElementById('calc-val').innerText = "Error"; } } }
        function openOS() { document.getElementById('rem-os').style.display = 'flex'; }
        function closeOS() { document.getElementById('rem-os').style.display = 'none'; }
        function showTab(t) { document.querySelectorAll('.os-tab').forEach(x => x.classList.add('hidden')); document.getElementById('tab-'+t).classList.remove('hidden'); }
    </script>
</body>
</html>
