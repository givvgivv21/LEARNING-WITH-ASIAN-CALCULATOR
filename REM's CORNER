<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>TI-84 Plus | v74 Double-Blind</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root { --bg: #2d2d2d; --lcd: #8b9a84; --orange: #f0810f; }
        body, html { margin: 0; padding: 0; height: 100vh; background: #000; font-family: monospace; overflow: hidden; perspective: 1000px; }

        /* 3D KINETIC HALO */
        .halo-container { position: absolute; top: -55px; left: 50%; transform: translateX(-50%); width: 180px; height: 60px; z-index: 5; pointer-events: none; }
        .halo { width: 100%; height: 100%; border: 4px solid #fff; border-radius: 50%; opacity: 0; filter: blur(1px) drop-shadow(0 0 20px #fff); transition: 0.8s; }
        .halo-active { opacity: 1; animation: orbitalSpin 4s linear infinite; }
        @keyframes orbitalSpin {
            0% { transform: rotateX(75deg) rotateY(10deg) rotateZ(0deg); }
            100% { transform: rotateX(75deg) rotateY(10deg) rotateZ(360deg); }
        }

        /* CALC CASE */
        .calc-case { background: var(--bg); border: 2px solid #111; width: 380px; padding: 25px; border-radius: 4px; position: absolute; top: 55%; left: 50%; transform: translate(-50%, -50%); z-index: 10; box-shadow: 0 30px 60px rgba(0,0,0,0.9); }
        .calc-lcd { background: var(--lcd); border: 4px solid #111; height: 80px; margin-bottom: 20px; padding: 15px; font-size: 2rem; text-align: right; color: #1a1a1a; line-height: 50px; font-weight: bold; }
        .calc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
        .btn { background: #3d3d3d; color: #fff; border-bottom: 4px solid #111; font-size: 1rem; font-weight: 900; padding: 12px 0; text-align: center; cursor: pointer; user-select: none; }
        .btn:active { transform: translateY(2px); border-bottom-width: 2px; }
        .orange { background: var(--orange) !important; color: #000 !important; }

        /* SIDEBAR HUD */
        #dash { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.98); z-index: 10000; flex-direction: row; }
        .sidebar { width: 300px; height: 100%; background: #050505; border-right: 1px solid #222; display: flex; flex-direction: column; padding: 40px 0; }
        .nav-item { padding: 15px 35px; color: #555; font-size: 12px; font-weight: 900; cursor: pointer; border-left: 3px solid transparent; transition: 0.2s; }
        .nav-item:hover { color: #fff; background: #111; border-left-color: #444; }
    </style>
</head>
<body onkeydown="if(event.key==='~'){panic()}">

    <div class="calc-case">
        <div class="halo-container"><div class="halo" id="halo"></div></div>
        <div id="display" class="calc-lcd">0</div>
        <div class="calc-grid">
            <div class="btn orange" onclick="press('2nd')">2nd</div>
            <div class="btn" onclick="press('AC')">AC</div>
            <div class="btn" onclick="press('/')">/</div>
            <div class="btn" onclick="press('*')">*</div>
            <div class="btn" onclick="press('7')">7</div>
            <div class="btn" onclick="press('8')">8</div>
            <div class="btn" onclick="press('9')">9</div>
            <div class="btn" onclick="press('-')">-</div>
            <div class="btn" onclick="press('4')">4</div>
            <div class="btn" onclick="press('5')">5</div>
            <div class="btn" onclick="press('6')">6</div>
            <div class="btn" onclick="press('+')">+</div>
            <div class="btn" onclick="press('1')">1</div>
            <div class="btn" onclick="press('2')">2</div>
            <div class="btn" onclick="press('3')">3</div>
            <div class="btn orange" onclick="press('ENTER')">EXE</div>
        </div>
    </div>

    <div id="dash">
        <div class="sidebar">
            <div class="px-10 mb-8"><h1 class="text-white text-xl font-black italic">OMNI_OS</h1></div>
            <div class="nav-item" onclick="blindLaunch('https://eaglercraft.q13x.com/', 'My Drive - Google Drive')">TAKAI MC (BLOB-INJECT)</div>
            <div class="nav-item" onclick="blindLaunch('https://www.google.com/search?igu=1', 'Google Classroom')">SEARCH (CLASSROOM MASK)</div>
            <div class="nav-item" onclick="spawnAI()">REM_AI (INTERNAL)</div>
            <div class="mt-auto nav-item text-red-700" onclick="panic()">FORCE TERMINATE</div>
        </div>
    </div>

    <script>
        let cur = "0"; 
        let is2nd = false;
        let activeWins = [];

        function press(k) {
            if (k === '2nd') { is2nd = !is2nd; document.getElementById('halo').classList.toggle('halo-active', is2nd); return; }
            if (is2nd && k === 'ENTER') { document.getElementById('dash').style.display = 'flex'; return; }
            if (k === 'AC') panic();
            else if (k === 'ENTER') try { cur = eval(cur.replace('×','*').replace('÷','/')) + ""; } catch { cur = "ERR"; }
            else cur = (cur === "0" ? k : cur + k);
            document.getElementById('display').innerText = cur;
        }

        // v74 DOUBLE-BLIND INJECTION ENGINE
        function blindLaunch(url, fakeTitle) {
            const win = window.open('about:blank', '_blank');
            if (!win) return alert("Enable popups for Stealth Mode.");

            // This content is written directly to the blank window's memory
            const content = `
                <!DOCTYPE html>
                <html>
                <head>
                    <title>${fakeTitle}</title>
                    <link rel="icon" href="https://ssl.gstatic.com/images/branding/product/1x/drive_2020q4_32dp.png">
                    <style>
                        body, html { margin:0; padding:0; height:100vh; width:100vw; background:#000; overflow:hidden; }
                        iframe { width:100%; height:100%; border:none; outline:none; }
                    </style>
                </head>
                <body>
                    <iframe src="${url}" referrerpolicy="no-referrer"></iframe>
                </body>
                </html>
            `;

            // Inject the content into the blank page
            win.document.open();
            win.document.write(content);
            win.document.close();

            activeWins.push(win);
            document.getElementById('dash').style.display = 'none';
        }

        function spawnAI() {
            const win = window.open('about:blank', '_blank');
            win.document.write('<body style="background:#000;color:#f0810f;font-family:monospace;padding:20px;"><h2>REM_AI_LOCAL</h2><p>Session-based logic only.</p></body>');
            activeWins.push(win);
        }

        function panic() {
            activeWins.forEach(w => { if(!w.closed) w.close(); });
            activeWins = [];
            document.getElementById('dash').style.display = 'none';
            document.getElementById('halo').classList.remove('halo-active');
            is2nd = false; cur = "0";
            document.getElementById('display').innerText = "0";
        }
    </script>
</body>
</html>
