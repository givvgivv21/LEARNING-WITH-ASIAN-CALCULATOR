<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>RemOS v26.0 | Khan Mastery Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/skinview3d@3.0.0/dist/skinview3d.bundle.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <style>
        :root { --khan-orange: #ff922b; --khan-blue: #14316d; --khan-green: #63d334; }
        body { background: #f8f9fa; color: #333; font-family: 'Plus Jakarta Sans', sans-serif; margin: 0; overflow: hidden; height: 100vh; }
        
        /* THE "LEARNING SITE" FAKE UI */
        .edu-sidebar { background: white; border-right: 4px solid #e9ecef; }
        .edu-card { background: white; border: 4px solid #ff922b; border-radius: 24px; box-shadow: 8px 8px 0px #ff922b; }
        .progress-bar { background: #e9ecef; border-radius: 10px; height: 20px; overflow: hidden; }
        .progress-fill { background: var(--khan-green); width: 65%; height: 100%; }

        /* BULKY ARITHMETIC CHALLENGE (CALC) */
        .calc-bezel { border: 10px solid var(--khan-blue); background: #f1f3f5; border-radius: 30px; box-shadow: 12px 12px 0px #14316d; }
        .calc-display { background: #fff; border: 4px inset #dee2e6; padding: 20px; text-align: right; color: var(--khan-blue); font-size: 2.5rem; font-family: 'JetBrains Mono'; border-radius: 15px; }
        .btn-bulky { background: white; border: 3px solid #dee2e6; border-radius: 15px; box-shadow: 4px 4px 0px #dee2e6; font-weight: 800; color: var(--khan-blue); transition: 0.1s; }
        .btn-bulky:active { transform: translate(2px, 2px); box-shadow: 0px 0px 0px #000; }
        .btn-orange { background: var(--khan-orange); color: white; border-color: #e67700; box-shadow: 4px 4px 0px #e67700; }

        /* OS OVERLAY (STAYS DARK/GITHUB STYLE) */
        #rem-os { position: fixed; inset: 0; background: #010409; z-index: 9999; display: none; padding: 30px; grid-template-columns: 300px 1fr; gap: 30px; }
        .os-tab { display: none; height: 100%; flex-direction: column; }
        .active-tab { display: flex !important; }
        
        /* COMBO OVERLAYS */
        #fake-code { position: fixed; inset: 0; background: rgba(0,0,0,0.9); color: #0f0; font-family: monospace; padding: 20px; z-index: 10000; display: none; pointer-events: none; }
    </style>
</head>
<body onkeydown="handleCombos(event)">

    <div id="fake-code"><code>> Initializing Python Runtime...<br>> Loading Linear_Algebra_Module...<br>> Processing data at 0x4F22...</code></div>

    <div class="flex h-screen">
        <div class="edu-sidebar w-72 p-8 flex flex-col gap-6">
            <div class="text-2xl font-black text-[#14316d] italic">KHAN<span class="text-orange-500">MASTERY</span></div>
            <div class="space-y-2">
                <div class="p-3 bg-orange-50 rounded-xl text-orange-600 font-bold text-sm">🏠 Dashboard</div>
                <div class="p-3 hover:bg-zinc-50 rounded-xl text-zinc-400 font-bold text-sm">📚 My Courses</div>
                <div class="p-3 hover:bg-zinc-50 rounded-xl text-zinc-400 font-bold text-sm">🏆 Achievements</div>
            </div>
            <div class="mt-auto p-4 bg-blue-50 rounded-2xl border-2 border-blue-100">
                <div class="text-[10px] font-black text-blue-800 uppercase mb-2">Daily Goal</div>
                <div class="progress-bar"><div class="progress-fill"></div></div>
                <div class="text-[10px] mt-2 text-blue-600">Keep up the great work, Rem!</div>
            </div>
        </div>

        <div class="flex-1 p-12 bg-[#fdfdfe] flex gap-12 items-center justify-center">
            
            <div class="edu-card flex-1 h-[600px] p-10 flex flex-col">
                <h2 class="text-4xl font-black text-[#14316d] mb-4">Welcome back, Scholar!</h2>
                <p class="text-zinc-500 mb-8">Ready to master your arithmetic goals today? Complete the challenge below to earn your next badge.</p>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="p-6 border-2 border-zinc-100 rounded-3xl flex items-center gap-4">
                        <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-green-600 font-bold">12</div>
                        <div><div class="text-xs font-black uppercase text-zinc-400">Current Streak</div><div class="text-lg font-bold">Days</div></div>
                    </div>
                    <div class="p-6 border-2 border-zinc-100 rounded-3xl flex items-center gap-4">
                        <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 font-bold">★</div>
                        <div><div class="text-xs font-black uppercase text-zinc-400">Mastery Points</div><div class="text-lg font-bold">4,250</div></div>
                    </div>
                </div>

                <div class="mt-auto flex justify-between items-center p-6 bg-orange-50 rounded-3xl border-2 border-orange-100">
                    <div>
                        <div class="text-xs font-black text-orange-800 uppercase">Current Unit</div>
                        <div class="font-bold text-[#14316d]">Advanced Computational Logic</div>
                    </div>
                    <button onclick="downloadSelf()" class="bg-[#14316d] text-white px-6 py-2 rounded-full font-bold text-xs">RESUME COURSE</button>
                </div>
            </div>

            <div class="calc-bezel w-[450px] p-8">
                <div class="text-center font-black text-[10px] text-blue-900 uppercase mb-4 tracking-widest">Mastery Challenge v26</div>
                <div class="calc-display mb-6" id="display">0</div>
                <div class="grid grid-cols-4 gap-3">
                    <button id="btn-2nd" class="btn-bulky h-16" onclick="toggle2nd()">2nd</button>
                    <button class="btn-bulky h-16" onclick="del()">DEL</button>
                    <button class="btn-bulky h-16" onclick="reset()">AC</button>
                    <button class="btn-bulky h-16 text-orange-600" onclick="op('/')">÷</button>
                    
                    <button class="btn-bulky h-16" onclick="press('7')">7</button>
                    <button class="btn-bulky h-16" onclick="press('8')">8</button>
                    <button class="btn-bulky h-16" onclick="press('9')">9</button>
                    <button class="btn-bulky h-16 text-orange-600" onclick="press('*')">×</button>
                    
                    <button class="btn-bulky h-16" onclick="press('4')">4</button>
                    <button class="btn-bulky h-16" onclick="press('5')">5</button>
                    <button class="btn-bulky h-16" onclick="press('6')">6</button>
                    <button class="btn-bulky h-16 text-orange-600" onclick="press('-')">-</button>
                    
                    <button class="btn-bulky h-16" onclick="press('1')">1</button>
                    <button class="btn-bulky h-16" onclick="press('2')">2</button>
                    <button class="btn-bulky h-16" onclick="press('3')">3</button>
                    <button class="btn-bulky h-16 text-orange-600" onclick="press('+')">+</button>
                    
                    <button class="btn-bulky h-16 col-span-2" onclick="press('0')">0</button>
                    <button class="btn-bulky h-16" onclick="press('.')">.</button>
                    <button class="btn-bulky h-16 btn-orange border-none" onclick="evalCalc()">=</button>
                </div>
            </div>
        </div>
    </div>

    <div id="rem-os">
        <div class="flex flex-col gap-4 border-r border-zinc-800 pr-6">
            <div class="text-white font-black text-xl italic mb-6">REMS_OS</div>
            <button onclick="showTab('bt')" class="bg-zinc-900 p-4 rounded-xl text-left font-bold text-orange-400 hover:bg-zinc-800">🥔 BROTATO</button>
            <button onclick="showTab('br')" class="bg-zinc-900 p-4 rounded-xl text-left font-bold text-blue-400 hover:bg-zinc-800">🌐 BROWSER (V2)</button>
            <button onclick="showTab('mc')" class="bg-zinc-900 p-4 rounded-xl text-left font-bold text-zinc-100 hover:bg-zinc-800">📦 MINECRAFT</button>
            <button onclick="closeOS()" class="mt-auto bg-red-900/20 text-red-500 p-4 rounded-xl font-bold">SHUTDOWN</button>
        </div>

        <div class="flex-1">
            <div id="tab-bt" class="os-tab h-full">
                <iframe src="https://blobby-boi.github.io/Brotato/" class="w-full h-full rounded-2xl border-none"></iframe>
            </div>
            <div id="tab-br" class="os-tab active-tab h-full flex flex-col">
                <div class="flex p-4 bg-zinc-900 gap-4 rounded-t-2xl border-b border-zinc-800">
                    <input type="text" id="url-input" class="flex-1 bg-black border-2 border-zinc-800 rounded px-4 py-2 text-white text-xs" placeholder="Search Google-IGU...">
                    <button onclick="goBrowser()" class="bg-blue-600 text-white px-8 rounded-xl font-bold text-xs">GO</button>
                </div>
                <iframe id="frame-browser" class="w-full flex-1 bg-white rounded-b-2xl" src="https://www.google.com/search?q=unblocked+github+games&igu=1"></iframe>
            </div>
            <div id="tab-mc" class="os-tab h-full">
                <iframe src="https://takaiwebsite.neocities.org/minecraft" class="w-full h-full rounded-2xl border-none"></iframe>
            </div>
        </div>
    </div>

    <script>
        let is2nd = false; let v = "0";
        
        function handleCombos(e) {
            if (e.key === '~') panic();
            if (e.shiftKey && e.key === '1') toggle('fake-code');
        }
        function toggle(id) { 
            const el = document.getElementById(id);
            el.style.display = el.style.display === 'block' ? 'none' : 'block';
        }
        function goBrowser() {
            const query = document.getElementById('url-input').value;
            const f = document.getElementById('frame-browser');
            f.src = query.includes('.') ? (query.startsWith('http') ? query : 'https://' + query) : `https://www.google.com/search?q=${encodeURIComponent(query)}&igu=1`;
        }
        function panic() { document.getElementById('rem-os').style.display = 'none'; document.getElementById('fake-code').style.display = 'none'; reset(); }
        function toggle2nd() { is2nd = !is2nd; document.getElementById('btn-2nd').style.background = is2nd ? '#ff922b' : 'white'; document.getElementById('btn-2nd').style.color = is2nd ? 'white' : '#14316d'; }
        function press(n) { v = (v === "0" ? n : v + n); document.getElementById('display').innerText = v; }
        function del() { v = v.slice(0, -1) || "0"; document.getElementById('display').innerText = v; }
        function reset() { v = "0"; document.getElementById('display').innerText = "0"; }
        function op(o) { if(is2nd && o === '/') { openOS(); toggle2nd(); } else press(o); }
        function evalCalc() { if(is2nd) { openOS(); toggle2nd(); } else { try { v = String(eval(v.replace('×','*').replace('÷','/'))); document.getElementById('display').innerText = v; } catch { document.getElementById('display').innerText = "ERR"; } } }
        
        function openOS() { document.getElementById('rem-os').style.display = 'grid'; }
        function closeOS() { document.getElementById('rem-os').style.display = 'none'; }
        
        // FIXED TAB SWITCHING
        function showTab(t) {
            const tabs = document.querySelectorAll('.os-tab');
            tabs.forEach(tab => tab.classList.remove('active-tab'));
            document.getElementById('tab-' + t).classList.add('active-tab');
        }

        function downloadSelf() { const b = new Blob([document.documentElement.outerHTML], {type: "text/html"}); const a = document.createElement("a"); a.href = URL.createObjectURL(b); a.download = "Khan_Academy_Mastery.html"; a.click(); }
    </script>
</body>
</html>
