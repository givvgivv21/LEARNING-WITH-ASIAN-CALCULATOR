<div id="rem-os" class="fixed inset-0 bg-[#0f172a] z-[3000] hidden flex-col font-sans">
    <div class="bg-[#1e293b] p-4 flex justify-between items-center border-b border-orange-500/30">
        <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <span class="font-black tracking-tighter text-orange-500">REM OS v4.0</span>
        </div>
        <button onclick="closeOS()" class="text-xs text-slate-500 hover:text-white">CLOSE [ESC]</button>
    </div>

    <div class="flex flex-1 overflow-hidden">
        <div class="w-64 bg-[#020617] p-6 space-y-2 border-r border-slate-800">
            <button onclick="showTab('mc')" class="w-full text-left p-3 rounded-xl hover:bg-orange-500/10 text-slate-400 hover:text-orange-500 transition">🎮 Gaming (Tuff)</button>
            <button onclick="showTab('ai')" class="w-full text-left p-3 rounded-xl hover:bg-indigo-500/10 text-slate-400 hover:text-indigo-400 transition">🤖 Rem-AI Console</button>
            <button onclick="showTab('links')" class="w-full text-left p-3 rounded-xl hover:bg-emerald-500/10 text-slate-400 hover:text-emerald-400 transition">🔗 The Link Vault</button>
            <button onclick="showTab('proxy')" class="w-full text-left p-3 rounded-xl hover:bg-red-500/10 text-slate-400 hover:text-red-400 transition">🌐 Frogiee Proxies</button>
        </div>

        <div class="flex-1 p-8 overflow-y-auto bg-[#0f172a] relative">
            
            <div id="tab-mc" class="os-tab hidden">
                <div class="bg-[#1e293b] rounded-3xl p-8 border border-slate-700 shadow-2xl">
                    <h2 class="text-3xl font-black mb-2">TUFF CLIENT</h2>
                    <p class="text-slate-500 mb-6">1.12.2 Optimized Eaglercraft</p>
                    <div class="grid grid-cols-2 gap-4 mb-8">
                        <div class="p-4 bg-black/20 rounded-xl border border-white/5">Optifine: <span class="text-green-500 font-bold">ACTIVE</span></div>
                        <div class="p-4 bg-black/20 rounded-xl border border-white/5">Eagler Forge: <span class="text-green-500 font-bold">READY</span></div>
                    </div>
                    <button onclick="startMinecraft()" class="w-full py-4 bg-green-600 hover:bg-green-500 rounded-xl font-bold text-xl shadow-lg shadow-green-900/20 transition">PLAY VERSION 1.12.2</button>
                </div>
            </div>

            <div id="tab-ai" class="os-tab hidden flex flex-col h-full">
                <div class="flex-1 bg-black/40 rounded-3xl p-6 border border-indigo-500/20 mb-4 font-mono text-sm overflow-y-auto" id="ai-chat">
                    <p class="text-indigo-400">// REM-AI TERMINAL INITIALIZED...</p>
                    <p class="text-slate-500">Connected to Neural-Link-4...</p>
                </div>
                <div class="flex gap-2">
                    <input type="text" id="ai-input" placeholder="Ask Rem-AI or Gemini..." class="flex-1 bg-[#1e293b] border border-slate-700 rounded-full px-6 py-3 focus:outline-none focus:border-indigo-500">
                    <button onclick="sendAI()" class="bg-indigo-600 px-6 py-3 rounded-full font-bold">SEND</button>
                </div>
            </div>

            <div id="tab-links" class="os-tab hidden">
                <h2 class="text-2xl font-bold mb-6 text-emerald-400">The Link Vault</h2>
                <div class="grid grid-cols-2 gap-4" id="vault-grid">
                    <p class="text-slate-500 italic">Send me your links and I will update this grid!</p>
                </div>
            </div>

            <div id="tab-proxy" class="os-tab hidden">
                <h2 class="text-2xl font-bold mb-6 text-red-400">Frogiee Network Mirrors</h2>
                <div class="space-y-4">
                    <button onclick="ghostLaunch(vault.f1, 'BYPASSING...')" class="w-full p-6 bg-slate-800 rounded-2xl border border-red-500/20 text-left hover:bg-slate-700">Mirror 1 (Primary)</button>
                    <button onclick="ghostLaunch(vault.f2, 'SYNCING...')" class="w-full p-6 bg-slate-800 rounded-2xl border border-red-500/20 text-left hover:bg-slate-700">Mirror 2 (Education Backup)</button>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    // --- MASTER OS LOGIC ---
    function showTab(tabId) {
        document.querySelectorAll('.os-tab').forEach(t => t.classList.add('hidden'));
        document.getElementById('tab-' + tabId).classList.remove('hidden');
    }

    function openOS() {
        document.getElementById('rem-os').classList.remove('hidden');
    }

    function closeOS() {
        document.getElementById('rem-os').classList.add('hidden');
    }

    // --- Master Calc Trigger ---
    function handleEnter() {
        if(is2ndActive) {
            openOS();
            reset2nd();
        } else {
            // Normal Math Calc Logic
            try {
                currentInput = eval(currentInput.replace('×', '*').replace('÷', '/'));
                screen.textContent = currentInput;
            } catch { screen.textContent = "Error"; }
        }
    }

    // --- Fake AI Logic ---
    function sendAI() {
        const input = document.getElementById('ai-input');
        const chat = document.getElementById('ai-chat');
        if(!input.value) return;

        chat.innerHTML += `<p class="text-white mt-2 font-bold">YOU: ${input.value}</p>`;
        
        // Simulating AI thinking
        setTimeout(() => {
            chat.innerHTML += `<p class="text-indigo-400 mt-2">REM-AI: Processing request using Gemini-X4... <br><span class="text-slate-300">Analysis complete. Proceeding with stealth protocols.</span></p>`;
            chat.scrollTop = chat.scrollHeight;
        }, 500);
        
        input.value = '';
    }

    // ... (Keep your existing toggle2nd and ghostLaunch functions) ...
</script>
