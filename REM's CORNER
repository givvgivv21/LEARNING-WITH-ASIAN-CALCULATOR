<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>OMNI-OS | v80 REM'S CORNER</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;700&family=Syncopate:wght@700&display=swap" rel="stylesheet">
    <style>
        :root { 
            --bg: #050705; --white: #ffffff; --green: #00ff41; 
            --glass: rgba(255, 255, 255, 0.03); --glow: 0 0 20px rgba(0, 255, 65, 0.6);
        }
        body, html { 
            margin: 0; padding: 0; height: 100vh; background: var(--bg);
            font-family: 'Space Grotesk', sans-serif; overflow: hidden; perspective: 1500px;
        }

        /* 3D QUANTUM HALO */
        .halo-anchor { position: absolute; top: 15%; left: 50%; transform: translateX(-50%); width: 260px; height: 90px; z-index: 5; pointer-events: none; }
        .ring { 
            position: absolute; inset: 0; border: 2px solid var(--white); border-radius: 50%; 
            opacity: 0; filter: blur(1px) drop-shadow(0 0 10px var(--green)); transition: 1s;
        }
        .ring-inner { border-color: var(--green); transform: scale(0.8); }
        .halo-active .ring { opacity: 0.8; animation: orbit 4s linear infinite; }
        @keyframes orbit {
            0% { transform: rotateX(75deg) rotateY(10deg) rotateZ(0deg); }
            100% { transform: rotateX(75deg) rotateY(10deg) rotateZ(360deg); }
        }

        /* QUANTUM CHASSIS (WHITE & GREEN) */
        .calc-body {
            background: var(--white); width: 380px; padding: 30px; border-radius: 4px;
            position: absolute; top: 55%; left: 50%; transform: translate(-50%, -50%);
            z-index: 10; box-shadow: 0 50px 100px rgba(0,0,0,0.8);
            border: 1px solid rgba(255,255,255,0.2);
        }
        .screen {
            background: #000; height: 90px; margin-bottom: 25px; padding: 20px;
            display: flex; align-items: flex-end; justify-content: flex-end;
            border-bottom: 5px solid var(--green);
        }
        .screen-text { color: var(--green); font-size: 2.5rem; font-weight: 700; text-shadow: var(--glow); font-family: 'Syncopate', sans-serif; }

        /* BUTTONS */
        .key-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
        .key {
            background: #f8f8f8; color: #111; padding: 18px 0; font-weight: 800;
            text-align: center; cursor: pointer; transition: 0.15s; border: 1px solid #ddd;
        }
        .key:hover { background: #000; color: var(--green); border-color: var(--green); box-shadow: var(--glow); }
        .key-prime { background: #111; color: #fff; border: none; }

        /* REM'S CORNER HUB */
        #ghost-hub {
            display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.95);
            z-index: 10000; backdrop-filter: blur(40px);
        }
        .ghost-side {
            width: 550px; height: 100%; background: var(--glass);
            border-right: 1px solid rgba(255,255,255,0.1); display: flex; flex-direction: column; padding: 60px 40px;
            overflow-y: auto;
        }
        .ascii-brand {
            font-family: monospace; font-size: 8px; line-height: 8px;
            color: var(--green); white-space: pre; margin-bottom: 40px;
            text-shadow: 0 0 5px var(--green);
        }
        .nav-item {
            padding: 20px; color: #fff; border-bottom: 1px solid rgba(255,255,255,0.05);
            cursor: pointer; transition: 0.3s; letter-spacing: 2px; font-weight: 700;
        }
        .nav-item:hover { color: var(--green); background: rgba(0,255,65,0.05); padding-left: 50px; }
    </style>
</head>
<body onkeydown="if(event.key==='~'){panic()}">

    <div class="calc-body">
        <div class="halo-anchor" id="halo-box"><div class="ring"></div><div class="ring ring-inner"></div></div>
        <div class="screen"><div id="disp" class="screen-text">0</div></div>
        <div class="key-grid">
            <div class="key key-prime" onclick="cmd('2nd')">2nd</div>
            <div class="key" onclick="cmd('AC')">CLR</div>
            <div class="key" onclick="press('/')">/</div>
            <div class="key" onclick="press('*')">×</div>
            <div class="key" onclick="press('7')">7</div>
            <div class="key" onclick="press('8')">8</div>
            <div class="key" onclick="press('9')">9</div>
            <div class="key" onclick="press('-')">-</div>
            <div class="key" onclick="press('4')">4</div>
            <div class="key" onclick="press('5')">5</div>
            <div class="key" onclick="press('6')">6</div>
            <div class="key" onclick="press('+')">+</div>
            <div class="key" onclick="press('1')">1</div>
            <div class="key" onclick="press('2')">2</div>
            <div class="key" onclick="press('3')">3</div>
            <div class="key key-prime" onclick="cmd('EXE')">EXE</div>
        </div>
    </div>

    <div id="ghost-hub">
        <div class="ghost-side">
            <div class="ascii-brand">
++++++   +++++++  ++      ++   +++++++  
++   ++  ++       +++    +++  ++        
++   ++  +++++    ++ +  + ++  +++++++   
++++++   ++       ++  ++  ++        ++  
++  ++   ++       ++      ++        ++  
++   ++  +++++++  ++      ++   +++++++  

+++++++   ++++++   +++++++   ++   ++  +++++++  ++++++  
++       ++    ++  ++    ++  +++  ++  ++       ++   ++ 
++       ++    ++  +++++++   ++ + ++  +++++    ++++++  
++       ++    ++  ++  ++    ++  +++  ++       ++  ++  
+++++++   ++++++   ++   ++   ++   ++  +++++++  ++   ++
</div>
            <p class="text-green-500 text-[10px] tracking-[5px] mb-8">SECURE ACCESS GRANTED // v80.0</p>
            
            <div class="nav-item" onclick="ghostLaunch('https://eaglercraft.q13x.com/', 'Assignment - Dashboard')">ACCESS: GHOST MINECRAFT</div>
            <div class="nav-item" onclick="ghostLaunch('https://takaiwebsite.neocities.org/brotato', 'Physics Simulation')">ACCESS: BROTATO CORE</div>
            <div class="nav-item" onclick="ghostLaunch('https://www.google.com/search?igu=1', 'Academic Search')">ACCESS: STEALTH GOOGLE</div>
            <div class="nav-item" onclick="spawnAI()">ACCESS: REM_AI_QUANTUM</div>
            
            <div class="mt-auto nav-item text-red-500" onclick="panic()">SYSTEM DISCONNECT (~)</div>
        </div>
    </div>

    <script>
        let val = "0"; let is2nd = false; let activeWins = [];

        function press(n) {
            val = (val === "0" ? n : val + n);
            document.getElementById('disp').innerText = val;
        }

        function cmd(k) {
            if (k === '2nd') { 
                is2nd = !is2nd; 
                document.getElementById('halo-box').classList.toggle('halo-active', is2nd); 
            }
            if (is2nd && k === 'EXE') { document.getElementById('ghost-hub').style.display = 'flex'; }
            if (k === 'AC') { val = "0"; document.getElementById('disp').innerText = "0"; }
            if (k === 'EXE' && !is2nd) {
                try { val = eval(val.replace('×','*').replace('÷','/')) + ""; } catch { val = "ERR"; }
                document.getElementById('disp').innerText = val;
            }
        }

        function ghostLaunch(url, mask) {
            const w = window.open('about:blank', '_blank');
            if(!w) return alert("Allow Popups.");
            const blob = new Blob([`
                <html><head><title>${mask}</title>
                <style>body,html,iframe{margin:0;padding:0;height:100%;width:100%;overflow:hidden;background:#000;border:none;}</style>
                </head><body><iframe src="${url}" referrerpolicy="no-referrer"></iframe></body></html>
            `], {type: 'text/html'});
            w.location.href = URL.createObjectURL(blob);
            activeWins.push(w);
            document.getElementById('ghost-hub').style.display = 'none';
        }

        function spawnAI() {
            const w = window.open('','','width=500,height=600');
            w.document.write('<body style="background:#000;color:#00ff41;font-family:monospace;padding:30px;"><h2>REMAI_QUANTUM_CORE</h2><p>Handshake confirmed. Signature: REMS_CORNER.</p></body>');
            activeWins.push(w);
        }

        function panic() {
            activeWins.forEach(w => { if(!w.closed) w.close(); });
            activeWins = [];
            document.getElementById('ghost-hub').style.display = 'none';
            document.getElementById('halo-box').classList.remove('halo-active');
            is2nd = false; val = "0";
            document.getElementById('disp').innerText = "0";
        }
    </script>
</body>
</html>
